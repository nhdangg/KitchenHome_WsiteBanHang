@model KitchenHome_WsiteBanHang.Models.NhatKyKho

@{
    ViewData["Title"] = "Tạo phiếu kho";
    Layout = "~/AreasThu_Kho/Views/Shared/_Layout.cshtml";
}

<div class="container" style="max-width: 700px">
    <div class="card shadow border-0 rounded-3">
        <div class="card-header bg-success text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-file-earmark-plus"></i> Tạo phiếu Nhập / Xuất Kho</h5>
        </div>
        <div class="card-body p-4">

            @* --- FORM BẮT ĐẦU --- *@
            <form asp-action="Create" method="post">

                @* Hiển thị lỗi tổng quát *@
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 border-start border-danger border-4 shadow-sm"></div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="LoaiPhatSinh" class="form-label fw-bold">Loại phiếu <span class="text-danger">*</span></label>
                        <select asp-for="LoaiPhatSinh" class="form-select text-center fw-bold text-primary" required>
                            <option value="NHAP">NHẬP HÀNG (+)</option>
                            <option value="XUAT">XUẤT HÀNG (-)</option>
                            <option value="DIEU_CHINH">ĐIỀU CHỈNH</option>
                        </select>
                        <span asp-validation-for="LoaiPhatSinh" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="KhoId" class="form-label fw-bold">Chọn Kho <span class="text-danger">*</span></label>
                        @* Cần ViewBag.KhoId từ Controller *@
                        <select asp-for="KhoId" class="form-select" asp-items="ViewBag.KhoId"></select>
                        <span asp-validation-for="KhoId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-2">
                    <label class="form-label fw-bold">Tìm sản phẩm</label>
                    <input type="text"
                           id="skuSearch"
                           class="form-control"
                           placeholder="🔍 Nhập SKU hoặc tên sản phẩm..." />
                </div>

                <div class="mb-3">
                    <label asp-for="BienTheId" class="form-label fw-bold">
                        Sản phẩm (SKU) <span class="text-danger">*</span>
                    </label>

                    <select asp-for="BienTheId"
                            class="form-select"
                            asp-items="ViewBag.BienTheId"
                            size="6"
                            required>
                        <option value="">-- Chọn sản phẩm --</option>
                    </select>

                    <span asp-validation-for="BienTheId" class="text-danger small"></span>
                </div>


                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="SoLuong" class="form-label fw-bold">Số lượng <span class="text-danger">*</span></label>
                        <input asp-for="SoLuong" class="form-control fw-bold" type="number" min="1" required />
                        <span asp-validation-for="SoLuong" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LoaiThamChieu" class="form-label fw-bold">Loại tham chiếu</label>
                        <input asp-for="LoaiThamChieu" class="form-control" placeholder="VD: PHIEU_NHAP_NCC" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="GhiChu" class="form-label fw-bold">Ghi chú / Lý do</label>
                    <textarea asp-for="GhiChu" class="form-control" rows="3" placeholder="Nhập lý do nhập xuất..."></textarea>
                </div>

                <hr class="text-muted opacity-25" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-secondary px-4">Hủy bỏ</a>
                    <button type="submit" class="btn btn-success px-4 fw-bold shadow-sm">
                        <i class="bi bi-save me-1"></i> Lưu phiếu & Cập nhật tồn
                    </button>
                </div>
            </form>
            @* --- FORM KẾT THÚC --- *@
        </div>
    </div>
</div>
<script>
    document.getElementById("skuSearch").addEventListener("keyup", function () {
        let keyword = this.value.toLowerCase();
        let select = document.querySelector("select[name='BienTheId']");
        let options = select.options;

        for (let i = 0; i < options.length; i++) {
            let text = options[i].text.toLowerCase();
            options[i].style.display = text.includes(keyword) ? "" : "none";
        }
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}