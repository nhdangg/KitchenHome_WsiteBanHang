@model ThuKhoDashboardViewModel

@{
    ViewData["Title"] = "Tổng Quan Kho Hàng";
    // Giả sử bạn đang dùng Layout Admin chung
     Layout = "~/Areas/Thu_Kho/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="container-fluid px-0 py-3">

    @* --- HEADER --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1 h3">
                <i class="bi bi-box-seam text-primary me-2"></i> Tổng Quan Kho Hàng
            </h2>
            <p class="text-muted mb-0 small">Báo cáo số liệu thống kê lưu trữ và quản lý kho</p>
        </div>
    </div>

    @* --- THẺ THỐNG KÊ (SUMMARY CARDS) --- *@
    <div class="row g-4 mb-4">

        @* 1. Tổng Sản Phẩm *@
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center p-3 me-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-box2-fill fs-3"></i>
                    </div>
                    <div>
                        <p class="text-muted small fw-bold mb-1 text-uppercase">Tổng sản phẩm</p>
                        <h3 class="fw-bold mb-0 text-dark">@Model.TongSanPham</h3>
                    </div>
                </div>
            </div>
        </div>

        @* 2. Tổng Biến Thể (SKU) *@
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center p-3 me-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-tags-fill fs-3"></i>
                    </div>
                    <div>
                        <p class="text-muted small fw-bold mb-1 text-uppercase">Tổng SKUs</p>
                        <h3 class="fw-bold mb-0 text-dark">@Model.TongBienThe</h3>
                    </div>
                </div>
            </div>
        </div>

        @* 3. Tổng Kho *@
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center p-3 me-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-buildings-fill fs-3"></i>
                    </div>
                    <div>
                        <p class="text-muted small fw-bold mb-1 text-uppercase">Tổng cơ sở kho</p>
                        <h3 class="fw-bold mb-0 text-dark">@Model.TongKho</h3>
                    </div>
                </div>
            </div>
        </div>

        @* 4. Tổng Tồn Kho *@
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center p-3 me-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-stack fs-3"></i>
                    </div>
                    <div>
                        <p class="text-muted small fw-bold mb-1 text-uppercase">Tổng tồn kho</p>
                        <h3 class="fw-bold mb-0 text-danger">@Model.TongSoLuongTon</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* --- BẢNG CHI TIẾT THEO KHO --- *@
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
            <h6 class="fw-bold mb-0 text-dark">
                <i class="bi bi-list-columns-reverse text-info me-2"></i> Chi tiết tình trạng từng kho
            </h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-muted text-uppercase small fw-bold" style="width: 40%;">Tên kho</th>
                            <th class="text-center py-3 text-muted text-uppercase small fw-bold" style="width: 20%;">Số biến thể</th>
                            <th class="text-center py-3 text-muted text-uppercase small fw-bold" style="width: 20%;">Tổng tồn</th>
                            <th class="text-end pe-4 py-3 text-muted text-uppercase small fw-bold" style="width: 20%;">Đang giữ chỗ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.DanhSachKho != null && Model.DanhSachKho.Any())
                        {
                            foreach (var kho in Model.DanhSachKho)
                            {
                                <tr>
                                    <td class="ps-4 py-3 fw-semibold text-dark">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded p-2 me-3 text-secondary">
                                                <i class="bi bi-shop"></i>
                                            </div>
                                            @kho.TenKho
                                        </div>
                                    </td>
                                    <td class="text-center py-3">
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-3 py-1">
                                            @kho.SoBienThe
                                        </span>
                                    </td>
                                    <td class="text-center py-3 fw-bold text-success fs-6">
                                        @kho.TongTon
                                    </td>
                                    <td class="text-end pe-4 py-3 fw-bold text-warning fs-6">
                                        @kho.TongGiuCho
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-inboxes display-4 d-block mb-3 opacity-50"></i>
                                    Chưa có dữ liệu kho hàng.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>