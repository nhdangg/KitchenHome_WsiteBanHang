@model KitchenHome_WsiteBanHang.Areas.Login_Wsite.Models.DangKyTKVM

@{
    ViewData["Title"] = "Tham gia Kitchen Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --glass-bg: rgba(255, 255, 255, 0.95);
    }

    body {
        background: #f0f2f5; /* Màu nền nhẹ nếu không dùng ảnh */
    }

    .register-section {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: url('https://images.unsplash.com/photo-1556911220-e15224bbafb0?q=80&w=2070&auto=format&fit=crop') no-repeat center center;
        background-size: cover;
        position: relative;
        padding: 40px 20px;
    }

        .register-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
        }

    .register-card {
        position: relative;
        width: 100%;
        max-width: 550px;
        background: var(--glass-bg);
        border-radius: 30px;
        padding: 45px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        animation: slideIn 0.7s ease-out;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .header-box {
        text-align: center;
        margin-bottom: 35px;
    }

    .register-title {
        font-weight: 800;
        color: #2d3436;
        font-size: 1.8rem;
        margin-bottom: 5px;
    }

    .form-floating > .form-control {
        border: 2px solid #f1f3f5;
        border-radius: 15px;
        transition: all 0.3s ease;
    }

        .form-floating > .form-control:focus {
            border-color: #764ba2;
            box-shadow: 0 0 0 4px rgba(118, 75, 162, 0.1);
        }

    .btn-register {
        background: var(--primary-gradient);
        border: none;
        border-radius: 15px;
        padding: 14px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s;
    }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(118, 75, 162, 0.3);
            filter: brightness(1.1);
        }

    .btn-back {
        border: 2px solid #eee;
        border-radius: 15px;
        padding: 12px;
        color: #636e72;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-back:hover {
            background: #f8f9fa;
            color: #2d3436;
        }

    .icon-badge {
        width: 60px;
        height: 60px;
        background: #f3f0ff;
        color: #764ba2;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 15px;
    }

    .input-icon {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #b2bec3;
        z-index: 10;
    }
</style>

<div class="register-section">
    <div class="register-card">
        <div class="header-box">
            <div class="icon-badge">
                <i class="bi bi-person-plus-fill"></i>
            </div>
            <h2 class="register-title">Tạo tài khoản mới</h2>
            <p class="text-muted">Đăng ký để nhận ưu đãi từ Kitchen Home</p>
        </div>

        <form asp-action="DangKy" method="post" class="row g-3">

            <div class="col-12">
                <div class="form-floating position-relative">
                    <input asp-for="TenDangNhap" class="form-control" placeholder="Tên đăng nhập" />
                    <label asp-for="TenDangNhap">Tên đăng nhập</label>
                    <i class="bi bi-person input-icon"></i>
                </div>
                <span asp-validation-for="TenDangNhap" class="text-danger small mt-1 d-block px-2"></span>
            </div>

            <div class="col-12">
                <div class="form-floating position-relative">
                    <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                    <label asp-for="Email">Địa chỉ Email</label>
                    <i class="bi bi-envelope input-icon"></i>
                </div>
                <span asp-validation-for="Email" class="text-danger small mt-1 d-block px-2"></span>
            </div>

            <div class="col-12">
                <div class="form-floating position-relative">
                    <input asp-for="SoDienThoai" class="form-control" placeholder="Số điện thoại" />
                    <label asp-for="SoDienThoai">Số điện thoại</label>
                    <i class="bi bi-phone input-icon"></i>
                </div>
                <span asp-validation-for="SoDienThoai" class="text-danger small mt-1 d-block px-2"></span>
            </div>

            <div class="col-md-6">
                <div class="form-floating position-relative">
                    <input asp-for="MatKhau" type="password" class="form-control" placeholder="Mật khẩu" id="pw" />
                    <label asp-for="MatKhau">Mật khẩu</label>
                    <i class="bi bi-shield-lock input-icon"></i>
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-floating position-relative">
                    <input asp-for="XacNhanMatKhau" type="password" class="form-control" placeholder="Xác nhận" id="confirm_pw" />
                    <label asp-for="XacNhanMatKhau">Xác nhận</label>
                    <i class="bi bi-check2-circle input-icon"></i>
                </div>
            </div>

            <div class="col-12 mb-2 px-2">
                <div class="form-check small">
                    <input class="form-check-input" type="checkbox" id="terms" required checked>
                    <label class="form-check-label text-muted" for="terms">
                        Tôi đồng ý với <a href="#" class="text-decoration-none" style="color:#764ba2">Điều khoản dịch vụ</a>
                    </label>
                </div>
            </div>

            <div class="col-12 pt-2">
                <button type="submit" class="btn btn-primary w-100 btn-register text-white shadow-sm">
                    Xác nhận đăng ký
                </button>
            </div>

            <div class="col-12">
                <a asp-action="Index" class="btn btn-light w-100 btn-back mt-2">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại đăng nhập
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Bạn có thể thêm logic JS để kiểm tra độ mạnh mật khẩu ở đây nếu muốn
    </script>
}