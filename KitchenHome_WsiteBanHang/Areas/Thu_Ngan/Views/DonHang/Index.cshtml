@using Microsoft.AspNetCore.Html
@model IEnumerable<KitchenHome_WsiteBanHang.Models.DonHang>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Areas/Thu_Ngan/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4 pt-2">
    <div>
        <h3 class="fw-bold text-success text-uppercase mb-0">
            <i class="bi bi-cash-coin me-2"></i>Danh sách đơn cần thu tiền
        </h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item">
                    <a asp-area="Thu_Ngan" asp-controller="Home" asp-action="Index">
                        Trang chủ
                    </a>
                </li>
                <li class="breadcrumb-item active">Đơn hàng</li>
            </ol>
        </nav>
    </div>
</div>

<!-- BỘ LỌC -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" class="row g-3 align-items-center">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text"
                           name="searchString"
                           value="@ViewBag.CurrentSearch"
                           class="form-control bg-light border-start-0"
                           placeholder="Mã đơn hoặc tên khách hàng..." />
                </div>
            </div>

            <div class="col-md-3">
                <select name="statusFilter" class="form-select bg-light border-0">
                    <option value="">-- Tất cả trạng thái --</option>
                    @{
                        var statuses = new Dictionary<string, string> {
                                        {"CHO_XAC_NHAN", "Chờ xác nhận"},
                                        {"DA_XAC_NHAN", "Đã xác nhận"},
                                        {"DANG_GIAO", "Đang giao"},
                                        {"DA_GIAO", "Đã giao"},
                                        {"HOAN_TAT", "Hoàn tất"},
                                        {"HUY", "Đã hủy"}
                                        };

                        foreach (var st in statuses)
                        {
                            <option value="@st.Key"
                                    selected="@(ViewBag.CurrentStatus == st.Key)">
                                @st.Value
                            </option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-auto">
                <button type="submit" class="btn btn-success px-4 shadow-sm">
                    Lọc
                </button>
                <a asp-area="Thu_Ngan"
                   asp-controller="DonHang"
                   asp-action="Index"
                   class="btn btn-outline-secondary border-0">
                    Reset
                </a>
            </div>
        </form>
    </div>
</div>

<!-- BẢNG DỮ LIỆU -->
<div class="card shadow-sm border-0 rounded-3 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small fw-bold text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Mã đơn</th>
                        <th>Ngày đặt</th>
                        <th>Khách hàng</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-success">
                                    #@item.MaDonHang
                                </td>

                                <td>
                                    <div>@item.NgayDat.ToString("dd/MM/yyyy")</div>
                                    <div class="small text-muted">
                                        @item.NgayDat.ToString("HH:mm")
                                    </div>
                                </td>

                                <td>
                                    @if (item.KhachHang != null)
                                    {
                                        <div class="fw-bold">
                                            @item.KhachHang.HoTen
                                        </div>
                                        <small class="text-muted">
                                            <i class="bi bi-telephone me-1"></i>
                                            @item.KhachHang.SoDienThoai
                                        </small>
                                    }
                                    else if (item.TaiKhoan != null)
                                    {
                                        <div class="fw-bold">
                                            @item.TaiKhoan.TenDangNhap
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">
                                            Không rõ danh tính
                                        </span>
                                    }
                                </td>

                                <td class="fw-bold text-danger">
                                    @item.TongTien.ToString("N0") ₫
                                </td>

                                <td>
                                    @Helper.RenderStatusBadge(item.TrangThai)
                                </td>

                                <td class="text-end pe-4">
                                    <a asp-area="Thu_Ngan"
                                       asp-controller="DonHang"
                                       asp-action="Details"
                                       asp-route-id="@item.DonHangId"
                                       class="btn btn-sm btn-light border shadow-sm">
                                        <i class="bi bi-eye text-info"></i> Xem
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6"
                                class="text-center py-5 text-muted">
                                Không tìm thấy đơn hàng nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- PHÂN TRANG -->
        @if (ViewBag.TotalPages > 1)
        {
            <div class="card-footer bg-white border-0 py-3">
                <nav>
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                <a class="page-link mx-1 rounded border-0"
                                   asp-area="Thu_Ngan"
                                   asp-controller="DonHang"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-searchString="@ViewBag.CurrentSearch"
                                   asp-route-statusFilter="@ViewBag.CurrentStatus">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@functions {
    public static class Helper
    {
        public static IHtmlContent RenderStatusBadge(string status)
        {
            string badgeClass = "bg-secondary";
            string label = status;

            switch (status)
            {
                case "CHO_XAC_NHAN":
                    badgeClass = "bg-warning text-dark";
                    label = "Chờ xác nhận";
                    break;

                case "DA_XAC_NHAN":
                    badgeClass = "bg-info text-dark";
                    label = "Đã xác nhận";
                    break;

                case "DANG_GIAO":
                    badgeClass = "bg-primary";
                    label = "Đang giao";
                    break;

                case "DA_GIAO":
                    badgeClass = "bg-success";
                    label = "Đã giao";
                    break;

                case "HOAN_TAT":
                    badgeClass = "bg-success";
                    label = "Hoàn tất";
                    break;

                case "HUY":
                    badgeClass = "bg-danger";
                    label = "Đã hủy";
                    break;

                default:
                    badgeClass = "bg-light text-dark";
                    break;
            }

            return new HtmlString(
                $"<span class='badge {badgeClass}'>{label}</span>");
        }
    }
}