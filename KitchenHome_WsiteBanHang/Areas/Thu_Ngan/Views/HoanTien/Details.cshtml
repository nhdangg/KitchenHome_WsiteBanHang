@model KitchenHome_WsiteBanHang.Models.HoanTien

@{
    ViewData["Title"] = "Chi tiết hoàn tiền";
    Layout = "~/Areas/Thu_Ngan/Views/Shared/_Layout.cshtml";
}

<div class="container py-4" style="max-width: 900px;">
    <div class="card shadow border-0 rounded-3">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-info-circle-fill me-2"></i>
                Chi tiết Yêu cầu #@Model.HoanTienId
            </h5>

            <div class="d-flex gap-2">
                <a asp-action="Index"
                   class="btn btn-sm btn-light text-secondary fw-bold shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>

                @* Ẩn nút Sửa nếu đã hoàn *@
                @if (Model.TrangThai != "DA_HOAN")
                {
                    <a asp-action="Edit"
                       asp-route-id="@Model.HoanTienId"
                       class="btn btn-sm btn-light text-primary fw-bold shadow-sm">
                        <i class="bi bi-pencil-square me-1"></i> Sửa
                    </a>
                }
            </div>
        </div>

        <div class="card-body p-4">
            <div class="row g-4">

                @* CỘT TRÁI: THÔNG TIN HOÀN TIỀN *@
                <div class="col-md-6">
                    <div class="p-3 bg-light rounded-3 h-100 border">
                        <h6 class="text-primary fw-bold text-uppercase small mb-3 border-bottom pb-2">
                            <i class="bi bi-arrow-return-left me-1"></i>
                            Thông tin Hoàn tiền
                        </h6>

                        <div class="mb-3">
                            <label class="text-muted small fw-bold">Số tiền hoàn:</label>
                            <div class="fs-4 fw-bold text-danger">
                                @Model.SoTienHoan.ToString("N0") ₫
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="text-muted small fw-bold">Trạng thái:</label>
                            <div>
                                @if (Model.TrangThai == "DA_HOAN")
                                {
                                    <span class="badge bg-success">Đã hoàn tiền</span>
                                }
                                else if (Model.TrangThai == "THAT_BAI")
                                {
                                    <span class="badge bg-danger">Thất bại</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Chờ xử lý</span>
                                }
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="text-muted small fw-bold">Ngày tạo:</label>
                            <div class="text-dark fw-bold">
                                @Model.NgayTao.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>

                        <div>
                            <label class="text-muted small fw-bold">Lý do:</label>
                            <div class="fst-italic bg-white p-2 rounded border">
                                "@Model.LyDo"
                            </div>
                        </div>
                    </div>
                </div>

                @* CỘT PHẢI: GIAO DỊCH GỐC *@
                <div class="col-md-6">
                    <div class="p-3 bg-white rounded-3 h-100 border border-secondary border-opacity-25">
                        <h6 class="text-secondary fw-bold text-uppercase small mb-3 border-bottom pb-2">
                            <i class="bi bi-receipt me-1"></i>
                            Giao dịch gốc
                        </h6>

                        <div class="mb-2">
                            <span class="d-block text-muted small fw-bold">
                                Mã đơn hàng:
                            </span>

                            <a asp-area="Thu_Ngan"
                               asp-controller="DonHang"
                               asp-action="Details"
                               asp-route-id="@Model.ThanhToan.DonHangId"
                               class="fw-bold fs-5 text-decoration-none">
                                @Model.ThanhToan?.DonHang?.MaDonHang
                            </a>
                        </div>

                        <div class="mb-2">
                            <span class="d-block text-muted small fw-bold">
                                Tổng tiền thanh toán:
                            </span>
                            <span class="fw-bold text-success">
                                @Model.ThanhToan?.SoTien.ToString("N0") ₫
                            </span>
                        </div>

                        <div class="mb-2">
                            <span class="d-block text-muted small fw-bold">
                                Phương thức:
                            </span>
                            <span class="badge bg-secondary">
                                @(Model.ThanhToan?.PhuongThuc?.TenPhuongThuc ?? "N/A")
                            </span>
                        </div>

                        <div class="mt-3 pt-3 border-top">
                            <a asp-area="Thu_Ngan"
                               asp-controller="ThanhToan"
                               asp-action="Details"
                               asp-route-id="@Model.ThanhToanId"
                               class="btn btn-sm btn-outline-secondary w-100">
                                Xem chi tiết giao dịch
                                <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>