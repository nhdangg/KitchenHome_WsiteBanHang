@model KitchenHome_WsiteBanHang.Models.TraHang
@{
    var donHang = ViewBag.DonHang as KitchenHome_WsiteBanHang.Models.DonHang;
    var danhSachDH = (ViewBag.DanhSachDonHang as IEnumerable<dynamic>) ?? new List<dynamic>();
}

<!-- HIỂN THỊ LỖI -->
<div asp-validation-summary="All"
     class="alert alert-danger shadow-sm @(ViewData.ModelState.IsValid ? "d-none" : "")">
    <h5 class="alert-heading">
        <i class="fas fa-exclamation-triangle"></i> Có lỗi xảy ra:
    </h5>
</div>

<div class="container-fluid px-4">
    <h2 class="mt-4">Tạo yêu cầu trả hàng</h2>

    <!-- CHỌN ĐƠN HÀNG -->
    <div class="card mb-4 border-primary">
        <div class="card-body">
            <label class="fw-bold mb-2">Bước 1: Chọn mã đơn hàng cần xử lý</label>
            <select id="selectDonHang" class="form-select form-select-lg">
                <option value="">-- Chọn mã đơn hàng --</option>
                @foreach (var dh in danhSachDH)
                {
                    <option value="@dh.DonHangId"
                            selected="@(donHang?.DonHangId == dh.DonHangId)">
                        @dh.MaDonHang
                    </option>
                }
            </select>
        </div>
    </div>

    @if (donHang != null)
    {
        <form asp-action="Create" method="post" id="formTraHang">
            @Html.AntiForgeryToken()
            <input type="hidden" name="DonHangId" value="@donHang.DonHangId" />

            <div class="row">
                <!-- CỘT TRÁI -->
                <div class="col-md-4">
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-primary text-white fw-bold">
                            Thông tin hoàn trả
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="fw-bold">Lý do trả hàng</label>
                                <textarea asp-for="LyDo" class="form-control"
                                          rows="3"
                                          placeholder="Nhập lý do khách trả..."></textarea>
                                <span asp-validation-for="LyDo" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label class="fw-bold">Số tiền dự kiến hoàn</label>
                                <input asp-for="SoTienDuKienHoan"
                                       id="TongTienHoan"
                                       class="form-control text-danger fw-bold"
                                       readonly />
                                <small class="text-muted fst-italic">
                                    * Tính theo các sản phẩm đã chọn
                                </small>
                            </div>

                            <button type="submit"
                                    class="btn btn-success w-100 fw-bold py-2">
                                <i class="fas fa-save me-1"></i> LƯU YÊU CẦU
                            </button>
                        </div>
                    </div>
                </div>

                <!-- CỘT PHẢI -->
                <div class="col-md-8">
                    <div class="card shadow-sm">
                        <div class="card-header fw-bold">
                            Danh sách sản phẩm có thể trả
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-bordered align-middle mb-0">
                                <thead class="table-dark text-center">
                                    <tr>
                                        <th width="50">Chọn</th>
                                        <th>Sản phẩm</th>
                                        <th width="90">SL Mua</th>
                                        <th width="110">SL Trả</th>
                                        <th width="140">Giá hoàn</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < donHang.ChiTietDonHangs.Count; i++)
                                    {
                                        var item = donHang.ChiTietDonHangs.ElementAt(i);
                                        <tr>
                                            <td class="text-center">
                                                <!-- QUAN TRỌNG: checkbox có name -->
                                                <input type="checkbox"
                                                       name="SelectedIndexes"
                                                       value="@i"
                                                       class="form-check-input item-check"
                                                       style="transform:scale(1.3)" />
                                            </td>

                                            <td>
                                                <strong>@item.TenSanPhamLuu</strong><br />
                                                <small class="text-muted">SKU: @item.Sku</small>

                                                <input type="hidden"
                                                       name="ChiTiet[@i].BienTheId"
                                                       value="@item.BienTheId"
                                                       disabled />
                                            </td>

                                            <td class="text-center">@item.SoLuong</td>

                                            <td>
                                                <input type="number"
                                                       name="ChiTiet[@i].SoLuong"
                                                       class="form-control sl-tra"
                                                       value="1"
                                                       min="1"
                                                       max="@item.SoLuong"
                                                       disabled />
                                            </td>

                                            <td>
                                                <input type="number"
                                                       name="ChiTiet[@i].DonGiaHoan"
                                                       class="form-control gia-hoan"
                                                       value="@item.DonGia"
                                                       readonly
                                                       disabled />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    }
</div>

@section Scripts {
    <script>
        $(function () {

            // đổi đơn hàng
            $('#selectDonHang').change(function () {
                let id = $(this).val();
                if (id) location.href = '/Admin/TraHang/Create?donHangId=' + id;
            });

            // tick sản phẩm
            $('.item-check').change(function () {
                let row = $(this).closest('tr');
                let checked = $(this).is(':checked');

                row.toggleClass('table-info', checked);
                row.find('input[name^="ChiTiet"]').prop('disabled', !checked);

                tinhTong();
            });

            $('.sl-tra').on('input change', tinhTong);

            function tinhTong() {
                let total = 0;
                $('.item-check:checked').each(function () {
                    let row = $(this).closest('tr');
                    let sl = parseFloat(row.find('.sl-tra').val()) || 0;
                    let gia = parseFloat(row.find('.gia-hoan').val()) || 0;
                    total += sl * gia;
                });
                $('#TongTienHoan').val(total);
            }

            // submit
            $('#formTraHang').submit(function (e) {
                let checked = $('.item-check:checked');
                if (checked.length === 0) {
                    e.preventDefault();
                    alert('⚠️ Vui lòng chọn ít nhất một sản phẩm để trả!');
                    return false;
                }

                checked.each(function () {
                    $(this).closest('tr')
                           .find('input[name^="ChiTiet"]')
                           .prop('disabled', false);
                });
                return true;
            });
        });
    </script>
}
