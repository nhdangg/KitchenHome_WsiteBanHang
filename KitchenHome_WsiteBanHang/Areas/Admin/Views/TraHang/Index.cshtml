@model IEnumerable<KitchenHome_WsiteBanHang.Models.TraHang>

@{
    ViewData["Title"] = "Quản lý trả hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-primary text-uppercase mb-0">
        <i class="bi bi-arrow-left-right me-2"></i>Quản lý trả hàng
    </h3>
    <a asp-action="Create" class="btn btn-primary px-3 shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> Thêm trả hàng
    </a>
</div>

<div class="card border-0 shadow-sm mb-4 bg-light">
    <div class="card-body p-3">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control border-start-0" placeholder="Tìm mã trả hàng hoặc mã đơn..." />
                </div>
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-filter me-1"></i> Lọc
                </button>
            </div>
            <div class="col-md-auto ms-auto">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-clockwise"></i> Reset
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-3 py-3">Mã phiếu</th>
                        <th>Đơn hàng</th>
                        <th>Ngày tạo</th>
                        <th>Tiền hoàn dự kiến</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-bold text-primary">@item.MaTraHang</td>
                            <td>
                                <span class="badge bg-light text-dark border fw-normal">
                                    <i class="bi bi-receipt me-1 text-muted"></i>#@item.DonHangId
                                </span>
                            </td>
                            <td class="small text-muted">
                                <div><i class="bi bi-calendar3 me-1"></i>@item.NgayTao.ToString("dd/MM/yyyy")</div>
                                <div><i class="bi bi-clock me-1"></i>@item.NgayTao.ToString("HH:mm")</div>
                            </td>
                            <td class="fw-bold text-danger">
                                @item.SoTienDuKienHoan.ToString("N0") <small>đ</small>
                            </td>
                            <td class="text-center">
                                @switch (item.TrangThai)
                                {
                                    case "YEU_CAU":
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2 rounded-pill small">Yêu cầu</span>
                                        break;
                                    case "HOAN_TAT":
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill small">Hoàn tất</span>
                                        break;
                                    default:
                                        <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-2 rounded-pill small">@item.TrangThai</span>
                                        break;
                                }
                            </td>
                            <td class="text-center pe-3">
                                <div class="d-flex justify-content-center gap-2">
                                    @* Nút Xem *@
                                    <a asp-action="Details" asp-route-id="@item.TraHangId" class="btn btn-sm btn-outline-info rounded-circle shadow-sm" title="Chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    @if (item.TrangThai == "YEU_CAU")
                                    {
                                        @* Nút Sửa *@
                                        <a asp-action="Edit" asp-route-id="@item.TraHangId" class="btn btn-sm btn-outline-warning rounded-circle shadow-sm" title="Chỉnh sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @* Nút Xóa *@
                                        <a asp-action="Delete" asp-route-id="@item.TraHangId" class="btn btn-sm btn-outline-danger rounded-circle shadow-sm" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    }

                                    @if (item.TrangThai != "HOAN_TAT")
                                    {
                                        @* Nút Hoàn tất (Xác nhận nhanh) *@
                                        <form asp-action="HoanTat" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.TraHangId" />
                                            <button type="submit" class="btn btn-sm btn-outline-success rounded-circle shadow-sm"
                                                    title="Xác nhận hoàn tất"
                                                    onclick="return confirm('Xác nhận đã xử lý xong và hoàn tất phiếu trả hàng này?')">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Đồng bộ CSS với các trang Admin khác */
    .table thead th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.02);
    }

    /* Style nút tròn thao tác */
    .btn-sm.rounded-circle {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }

    /* Badge phong cách subtle (nhẹ) */
    .bg-success-subtle {
        background-color: #d1e7dd !important;
    }

    .bg-warning-subtle {
        background-color: #fff3cd !important;
    }

    .bg-info-subtle {
        background-color: #cff4fc !important;
    }
</style>