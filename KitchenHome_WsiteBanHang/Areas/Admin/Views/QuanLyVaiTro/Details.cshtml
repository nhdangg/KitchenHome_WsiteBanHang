@model KitchenHome_WsiteBanHang.Areas.Admin.Models.VaiTroDetailVM

@{
    ViewData["Title"] = "Chi tiết vai trò";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container py-4" style="max-width: 900px;">

    @* --- KHUNG CARD CHÍNH --- *@
    <div class="card shadow border-0 rounded-3">

        @* --- HEADER: Tiêu đề & Nút thao tác --- *@
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-info-circle-fill me-2"></i>Chi tiết Vai trò
            </h5>
            <div class="d-flex gap-2">
                @* Nút Quay lại *@
                <a asp-action="Index" class="btn btn-sm btn-light text-secondary fw-bold shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>

                @* Nút Sửa *@
                <a asp-action="Edit" asp-route-id="@Model.VaiTro.VaiTroId" class="btn btn-sm btn-light text-primary fw-bold shadow-sm">
                    <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa
                </a>
            </div>
        </div>

        @* --- BODY: Nội dung chi tiết --- *@
        <div class="card-body p-4">

            @* 1. THÔNG TIN CHUNG (Chia 2 cột) *@
            <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                    <label class="text-muted small fw-bold text-uppercase mb-1">Mã vai trò</label>
                    <div class="d-flex align-items-center">
                        <span class="fs-5 fw-bold text-primary font-monospace bg-light px-3 py-2 rounded border">
                            @Model.VaiTro.MaVaiTro
                        </span>
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="text-muted small fw-bold text-uppercase mb-1">Tên vai trò</label>
                    <p class="fs-5 fw-bold text-dark border-bottom pb-2">
                        @Model.VaiTro.TenVaiTro
                    </p>
                </div>
            </div>

            @* Đường kẻ phân cách mờ *@
            <hr class="bg-secondary opacity-25 my-4">

            @* 2. DANH SÁCH TÀI KHOẢN *@
            <div class="d-flex justify-content-between align-items-end mb-3">
                <h6 class="fw-bold text-dark mb-0">
                    <i class="bi bi-people-fill me-2 text-info"></i>
                    Danh sách tài khoản thuộc vai trò này
                </h6>
                <span class="badge bg-info rounded-pill px-3 py-2">
                    Tổng: @Model.TongTaiKhoan
                </span>
            </div>

            <div class="table-responsive border rounded-3">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-3 py-2">ID</th>
                            <th>Tên đăng nhập</th>
                            <th>Email</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.TaiKhoans != null && Model.TaiKhoans.Any())
                        {
                            foreach (var tk in Model.TaiKhoans)
                            {
                                <tr>
                                    <td class="ps-3 text-muted small font-monospace">#@tk.TaiKhoanId</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded-circle p-2 me-2 text-secondary">
                                                <i class="bi bi-person-fill"></i>
                                            </div>
                                            <span class="fw-bold text-dark">@tk.TenDangNhap</span>
                                        </div>
                                    </td>
                                    <td class="text-secondary">@tk.Email</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center py-4 text-muted">
                                    <i class="bi bi-person-x display-6 d-block mb-2 opacity-25"></i>
                                    Chưa có tài khoản nào được gán vai trò này.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>