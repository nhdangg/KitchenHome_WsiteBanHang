@model IEnumerable<KitchenHome_WsiteBanHang.Models.DanhMuc>

@{
    ViewData["Title"] = "Quản lý danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-primary text-uppercase mb-0">
        <i class="bi bi-list-ul me-2"></i>Danh mục sản phẩm
    </h3>
    <a asp-action="Create" class="btn btn-primary px-3 shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> Thêm mới
    </a>
</div>

<div class="card border-0 shadow-sm mb-4 bg-light">
    <div class="card-body p-3">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control border-start-0" placeholder="Tìm tên danh mục..." />
                </div>
            </div>

            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">-- Trạng thái --</option>
                    <option value="true" selected="@(ViewBag.Status?.ToString() == "True")">Đang hoạt động</option>
                    <option value="false" selected="@(ViewBag.Status?.ToString() == "False")">Tạm khóa</option>
                </select>
            </div>

            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-filter me-1"></i> Lọc
                </button>
            </div>

            <div class="col-md-auto ms-auto">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-clockwise"></i> Reset
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-3 py-3">Tên danh mục</th>
                        <th>Slug (URL)</th>
                        <th>Danh mục cha</th>
                        <th class="text-center">Thứ tự</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold ps-3 text-primary">@item.TenDanhMuc</td>
                                <td class="text-muted small fst-italic">@item.Slug</td>
                                <td>
                                    @if (item.DanhMucCha != null)
                                    {
                                        <span class="badge bg-light text-dark border fw-normal">
                                            <i class="bi bi-arrow-return-right me-1 text-muted"></i> @item.DanhMucCha.TenDanhMuc
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary opacity-75 fw-normal">-- Gốc --</span>
                                    }
                                </td>
                                <td class="text-center fw-bold">@item.ThuTu</td>
                                <td class="text-center">
                                    @if (item.DangHoatDong == true)
                                    {
                                        <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-x-circle-fill text-secondary fs-5"></i>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Details" asp-route-id="@item.DanhMucId" class="btn btn-sm btn-outline-info rounded-circle"><i class="bi bi-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@item.DanhMucId" class="btn btn-sm btn-outline-warning rounded-circle"><i class="bi bi-pencil"></i></a>
                                        <form asp-action="Delete" asp-route-id="@item.DanhMucId" method="post" class="d-inline" onsubmit="return confirm('Xóa danh mục: @item.TenDanhMuc?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@{
    int totalPages = (int)Math.Ceiling((double)ViewBag.TotalItems / ViewBag.PageSize);
}

@if (totalPages > 1)
{
    <nav class="mt-4">
        @* Thay đổi justify-content-center thành justify-content-end *@
        <ul class="pagination justify-content-end pagination-clean">
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-search="@ViewBag.Search"
                   asp-route-status="@ViewBag.Status">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link shadow-none" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@ViewBag.Search"
                       asp-route-status="@ViewBag.Status">@i</a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-search="@ViewBag.Search"
                   asp-route-status="@ViewBag.Status">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
        @* Hiển thị số lượng bản ghi nếu muốn chuyên nghiệp hơn *@
        <div class="text-end text-muted small mt-2 pe-1">
            Hiển thị trang @ViewBag.CurrentPage / @totalPages
        </div>
    </nav>
}

<style>
    /* Giữ nguyên Style cũ và thêm một chút căn chỉnh */
    .pagination-clean .page-link {
        border: none;
        color: #6c757d;
        margin-left: 6px; /* Tạo khoảng cách giữa các nút */
        border-radius: 8px !important;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        background-color: #f8f9fa;
    }

    .pagination-clean .page-item.active .page-link {
        background-color: #0d6efd;
        color: white;
        box-shadow: 0 3px 8px rgba(13, 110, 253, 0.3);
        font-weight: bold;
    }

    .pagination-clean .page-link:hover:not(.active) {
        background-color: #dee2e6;
        color: #333;
    }

    .pagination-clean .page-item.disabled .page-link {
        background-color: #f8f9fa;
        opacity: 0.5;
    }
</style>