@model KitchenHome_WsiteBanHang.Models.NhatKyHeThong

@{
    ViewData["Title"] = "Chi tiết nhật ký";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<style>
    .log-label {
        width: 140px;
        color: #6c757d;
        font-weight: 600;
    }

    .data-container {
        max-height: 400px;
        overflow-y: auto;
        font-family: 'Cascadia Code', Consolas, monospace;
        font-size: 0.85rem;
    }

    .badge-action {
        padding: 0.5em 1em;
        border-radius: 50px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .card-custom {
        border-radius: 15px;
        border: none;
        transition: all 0.3s;
    }

    .info-group {
        border-left: 3px solid #0d6efd;
        padding-left: 15px;
        margin-bottom: 20px;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Hệ thống</a></li>
                    <li class="breadcrumb-item active">Nhật ký</li>
                </ol>
            </nav>
            <h3 class="fw-bold mb-0 text-dark">
                <i class="bi bi-shield-lock-fill text-primary me-2"></i>Chi tiết Log #@Model.NhatKyId
            </h3>
        </div>
        <a asp-action="Index" class="btn btn-light shadow-sm border rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="card card-custom shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold"><i class="bi bi-info-circle me-2"></i>Thông tin cơ bản</h6>
                </div>
                <div class="card-body">
                    <div class="info-group">
                        <small class="text-muted d-block">Thời gian hệ thống</small>
                        <span class="fw-bold text-dark">@Model.NgayTao.ToString("dd/MM/yyyy HH:mm:ss")</span>
                    </div>

                    <div class="info-group border-primary">
                        <small class="text-muted d-block">Hành động thực hiện</small>
                        @{
                            var badgeClass = Model.HanhDong.ToUpper() switch
                            {
                                "INSERT" => "bg-success",
                                "UPDATE" => "bg-warning text-dark",
                                "DELETE" => "bg-danger",
                                _ => "bg-primary"
                            };
                        }
                        <span class="badge @badgeClass badge-action mt-1">@Model.HanhDong</span>
                    </div>

                    <div class="info-group border-info">
                        <small class="text-muted d-block">Đối tượng tác động</small>
                        <span class="text-dark">Bảng: <strong>@Model.TenBang</strong></span>
                        <div class="mt-1">
                            <small class="text-muted">ID bản ghi:</small>
                            <code class="user-select-all">@Model.KhoaBanGhi</code>
                        </div>
                    </div>

                    <div class="list-group list-group-flush small">
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span class="text-muted"><i class="bi bi-person me-2"></i>Người thực hiện</span>
                            <span class="fw-bold">@(Model.TaiKhoan?.TenDangNhap ?? "Hệ thống")</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0 border-0">
                            <span class="text-muted"><i class="bi bi-pc-display me-2"></i>Địa chỉ IP</span>
                            <span class="badge bg-light text-dark border">@Model.DiaChiIp</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card card-custom shadow-sm overflow-hidden">
                <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
                    <h6 class="m-0 fw-bold"><i class="bi bi-code-square me-2"></i>Nội dung thay đổi dữ liệu</h6>
                    <span class="badge bg-light text-muted fw-normal">Định dạng: JSON/Text</span>
                </div>
                <div class="card-body p-0">
                    <div class="row g-0">
                        <div class="col-md-6 border-end">
                            <div class="bg-danger bg-opacity-10 p-2 border-bottom">
                                <small class="text-danger fw-bold"><i class="bi bi-dash-circle me-1"></i>DỮ LIỆU TRƯỚC (OLD)</small>
                            </div>
                            <div class="p-3 data-container">
                                @if (string.IsNullOrEmpty(Model.DuLieuCu))
                                {
                                    <em class="text-muted">Không có dữ liệu cũ</em>
                                }
                                else
                                {
                                    <pre class="m-0">@Model.DuLieuCu</pre>
                                }
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="bg-success bg-opacity-10 p-2 border-bottom">
                                <small class="text-success fw-bold"><i class="bi bi-plus-circle me-1"></i>DỮ LIỆU SAU (NEW)</small>
                            </div>
                            <div class="p-3 data-container">
                                @if (string.IsNullOrEmpty(Model.DuLieuMoi))
                                {
                                    <em class="text-muted">Không có dữ liệu mới</em>
                                }
                                else
                                {
                                    <pre class="m-0 text-success">@Model.DuLieuMoi</pre>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light p-2 text-center">
                    <small class="text-muted italic"><i class="bi bi-info-circle me-1"></i>Dữ liệu này được ghi lại tự động bởi trình theo dõi hệ thống (Audit Trail).</small>
                </div>
            </div>
        </div>
    </div>
</div>