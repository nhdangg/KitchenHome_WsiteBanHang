@model IEnumerable<KitchenHome_WsiteBanHang.Models.NhatKyHeThong>
@{
    ViewData["Title"] = "Nhật ký hệ thống";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-primary text-uppercase mb-0">
        <i class="bi bi-shield-lock me-2"></i>Nhật ký hệ thống
    </h3>
    @* Nút dọn dẹp nhanh *@
    <form asp-action="CleanLog" method="post" onsubmit="return confirm('Dọn dẹp nhật ký cũ hơn 3 tháng?');">
        <button type="submit" class="btn btn-outline-danger rounded-pill px-3 shadow-sm">
            <i class="bi bi-trash3 me-1"></i> Dọn dẹp log cũ
        </button>
    </form>
</div>

<div class="card border-0 shadow-sm mb-4 bg-light">
    <div class="card-body p-3">
        <form method="get" class="row g-2">
            <div class="col-md-3">
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm tài khoản, ID..." />
            </div>
            <div class="col-md-2">
                <select name="actionType" class="form-select">
                    <option value="">-- Hành động --</option>
                    @foreach (var act in ViewBag.Actions)
                    {
                        <option value="@act" selected="@(ViewBag.ActionType == act)">@act</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="tableName" class="form-select">
                    <option value="">-- Bảng --</option>
                    @foreach (var tbl in ViewBag.Tables)
                    {
                        <option value="@tbl" selected="@(ViewBag.TableName == tbl)">@tbl</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control" />
            </div>
            <div class="col-md-2">
                <input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control" />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-filter"></i></button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary">
                <tr>
                    <th class="ps-3 py-3">Thời gian</th>
                    <th>Tài khoản</th>
                    <th class="text-center">Hành động</th>
                    <th>Bảng</th>
                    <th>ID bản ghi</th>
                    <th>Địa chỉ IP</th>
                    <th class="text-center">Xem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3">
                            <div class="small fw-bold text-dark">@item.NgayTao.ToString("dd/MM/yyyy")</div>
                            <div class="text-muted" style="font-size: 0.75rem;">@item.NgayTao.ToString("HH:mm:ss")</div>
                        </td>
                        <td>
                            <span class="fw-bold text-primary">@(item.TaiKhoan?.TenDangNhap ?? "Hệ thống")</span>
                        </td>
                        <td class="text-center">
                            @if (item.HanhDong == "DELETE")
                            {
                                <span class="badge bg-danger-subtle text-danger rounded-pill">DELETE</span>
                            }
                            else if (item.HanhDong == "UPDATE")
                            {

                                <span class="badge bg-warning-subtle text-warning rounded-pill">UPDATE</span>
                            }
                            else
                            {

                                <span class="badge bg-success-subtle text-success rounded-pill">@item.HanhDong</span>
                            }
                        </td>
                        <td class="fw-medium">@item.TenBang</td>
                        <td><code class="text-dark">@item.KhoaBanGhi</code></td>
                        <td class="small text-muted">@item.DiaChiIp</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.NhatKyId" class="btn btn-sm btn-outline-info rounded-circle">
                                <i class="bi bi-search"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>