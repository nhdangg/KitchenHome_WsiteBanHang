@model KitchenHome_WsiteBanHang.Models.HoanTien

@{
    ViewData["Title"] = "Cập nhật hoàn tiền";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow border-0 border-top border-warning border-3 rounded-3">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-warning text-uppercase"><i class="bi bi-pencil-square me-2"></i>Cập nhật yêu cầu</h5>
                </div>
                <div class="card-body p-4">

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show mb-3"><i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                    }

                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="HoanTienId" />
                        <input type="hidden" asp-for="NgayTao" />

                        @* ID Giao dịch gốc (Ẩn) *@
                        <input type="hidden" asp-for="ThanhToanId" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        @* Hiển thị thông tin giao dịch gốc (Read only) *@
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">Giao dịch gốc (Không được sửa)</label>
                            <input type="text" class="form-control bg-light" value="@ViewData["ThanhToanInfo"]" readonly />
                        </div>

                        <div class="mb-3">
                            <label asp-for="SoTienHoan" class="form-label fw-bold">Số tiền hoàn (VNĐ)</label>
                            <div class="input-group">
                                <input asp-for="SoTienHoan" class="form-control text-end fw-bold" type="number" />
                                <span class="input-group-text">₫</span>
                            </div>
                            <span asp-validation-for="SoTienHoan" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LyDo" class="form-label fw-bold">Lý do hoàn tiền</label>
                            <textarea asp-for="LyDo" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="LyDo" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="TrangThai" class="form-label fw-bold">Trạng thái xử lý</label>
                            <select asp-for="TrangThai" class="form-select form-select-lg fw-bold border-warning text-dark" asp-items="ViewBag.TrangThaiList"></select>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-action="Index" class="btn btn-secondary px-4 shadow-sm">Quay lại</a>
                            <button type="submit" class="btn btn-warning px-4 fw-bold shadow-sm"><i class="bi bi-check-lg me-1"></i> Cập nhật</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}