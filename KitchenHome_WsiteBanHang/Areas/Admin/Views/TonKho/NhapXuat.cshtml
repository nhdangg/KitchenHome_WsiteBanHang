@model KitchenHome_WsiteBanHang.Models.TonKho

@{
    ViewData["Title"] = "Nhập / Xuất kho";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">

    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="bi bi-box-seam me-2"></i>
                Nhập / Xuất kho
            </h5>
        </div>

        <div class="card-body">

            <!-- Thông tin sản phẩm -->
            <div class="mb-4">
                <h6><strong>SKU:</strong> @Model.BienThe?.Sku</h6>
                <h6>
                    <strong>Tồn hiện tại:</strong>
                    <span class="text-success fs-5">
                        @Model.SoLuongTon
                    </span>
                </h6>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @Html.Raw(TempData["Error"])
                </div>
            }

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            <form asp-action="NhapXuat" method="post">

                <input type="hidden" name="khoId" value="@Model.KhoId" />
                <input type="hidden" name="bienTheId" value="@Model.BienTheId" />
                <input type="hidden" name="returnKhoId" value="@ViewBag.ReturnKhoId" />

                <!-- Loại -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Loại thao tác</label>
                    <select name="loai" class="form-select" required>
                        <option value="NHAP">Nhập kho</option>
                        <option value="XUAT">Xuất kho</option>
                    </select>
                </div>

                <!-- Số lượng -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Số lượng</label>
                    <input type="number"
                           name="soLuong"
                           class="form-control"
                           min="1"
                           required />
                </div>

                <!-- Ghi chú -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Ghi chú</label>
                    <textarea name="ghiChu"
                              class="form-control"
                              rows="3"
                              placeholder="Nhập lý do nhập/xuất..."></textarea>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-controller="Kho"
                       asp-action="Details"
                       asp-route-id="@ViewBag.ReturnKhoId"
                       class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>

                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle"></i> Xác nhận
                    </button>
                </div>

            </form>
        </div>
    </div>

</div>