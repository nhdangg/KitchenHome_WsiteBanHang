@model KitchenHome_WsiteBanHang.Models.Kho

@{
    ViewData["Title"] = "Cập nhật kho";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container py-4" style="max-width: 700px">
    <div class="d-flex align-items-center mb-3">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-circle me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h4 class="fw-bold mb-0">Cập nhật thông tin Kho</h4>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="KhoId" />

                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Mã Kho</label>
                    <input asp-for="MaKho" class="form-control bg-light" readonly />
                    <div class="form-text small">Mã định danh duy nhất của kho hàng.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Tên Kho <span class="text-danger">*</span></label>
                    <input asp-for="TenKho" class="form-control" placeholder="VD: Kho Tổng Hà Nội" required />
                    <span asp-validation-for="TenKho" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Địa chỉ chi tiết</label>
                    <textarea asp-for="DiaChi" class="form-control" rows="3" placeholder="Số nhà, đường, quận/huyện..."></textarea>
                </div>

                <div class="bg-light p-3 rounded-3 mb-4">
                    <div class="form-check form-switch mb-0">
                        <input asp-for="DangHoatDong" class="form-check-input" type="checkbox" role="switch">
                        <label class="form-check-label fw-bold ms-2">Trạng thái hoạt động</label>
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end border-top pt-3">
                    <a asp-action="Index" class="btn btn-light px-4 border">Hủy bỏ</a>
                    <button type="submit" class="btn btn-warning px-4 fw-bold">
                        <i class="bi bi-check-lg me-1"></i> Lưu cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>