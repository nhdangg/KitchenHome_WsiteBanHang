@model KitchenHome_WsiteBanHang.Models.DanhGiaSanPham

@{
    ViewData["Title"] = "Chi tiết đánh giá";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary text-uppercase mb-0">
            <i class="bi bi-info-circle me-2"></i>Chi tiết đánh giá
        </h3>
        <a asp-action="Index" class="btn btn-outline-secondary px-3 shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
                @* Header với dải màu nhẹ đồng bộ *@
                <div class="card-header bg-light border-bottom py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted fw-bold small text-uppercase">Mã đánh giá: #@Model.DanhGiaId</span>
                        @if (Model.HienThi)
                        {
                            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill">
                                <i class="bi bi-check-circle-fill me-1"></i> Đang hiển thị
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2 rounded-pill">
                                <i class="bi bi-eye-slash-fill me-1"></i> Đang ẩn
                            </span>
                        }
                    </div>
                </div>

                <div class="card-body p-4">
                    <div class="row g-4">
                        @* Cột thông tin khách hàng & sản phẩm *@
                        <div class="col-md-5 border-end">
                            <div class="mb-4">
                                <label class="text-secondary small fw-bold text-uppercase d-block mb-2">Khách hàng</label>
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                        <i class="bi bi-person-fill fs-4"></i>
                                    </div>
                                    <div>
                                        <h5 class="fw-bold mb-0 text-dark">@(Model.KhachHang?.HoTen ?? "Khách vãng lai")</h5>
                                        <span class="text-muted small"><i class="bi bi-telephone me-1"></i>@Model.KhachHang?.SoDienThoai</span>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="text-secondary small fw-bold text-uppercase d-block mb-2">Sản phẩm</label>
                                <div class="p-3 bg-light rounded-3 border">
                                    <h6 class="fw-bold mb-1 text-primary">@Model.SanPham?.TenSanPham</h6>
                                    <span class="text-muted small">Mã SP: #@Model.SanPhamId</span>
                                </div>
                            </div>

                            <div class="mb-0">
                                <label class="text-secondary small fw-bold text-uppercase d-block mb-2">Thời gian</label>
                                <div class="text-dark fw-medium">
                                    <i class="bi bi-calendar3 me-2 text-muted"></i>@Model.NgayTao.ToString("dd/MM/yyyy")
                                    <span class="mx-2 text-light">|</span>
                                    <i class="bi bi-clock me-2 text-muted"></i>@Model.NgayTao.ToString("HH:mm:ss")
                                </div>
                            </div>
                        </div>

                        @* Cột nội dung đánh giá *@
                        <div class="col-md-7 ps-md-4">
                            <div class="mb-4">
                                <label class="text-secondary small fw-bold text-uppercase d-block mb-2">Xếp hạng</label>
                                <div class="text-warning fs-3">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi bi-star-fill @(i <= Model.SoSao ? "" : "text-secondary opacity-25")"></i>
                                    }
                                    <span class="text-dark fs-5 fw-bold ms-2">@Model.SoSao/5</span>
                                </div>
                            </div>

                            <div class="mb-0">
                                <label class="text-secondary small fw-bold text-uppercase d-block mb-2">Nội dung phản hồi</label>
                                <div class="bg-light p-4 rounded-3 border-0 shadow-none position-relative">
                                    <i class="bi bi-quote position-absolute text-primary opacity-25" style="font-size: 3rem; top: -10px; left: 10px;"></i>
                                    <h5 class="fw-bold text-dark position-relative mb-3 pt-2">@Model.TieuDe</h5>
                                    <p class="text-muted fst-italic mb-0 position-relative lh-lg">
                                        "@Model.NoiDung"
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* Footer với các nút thao tác tròn đồng bộ *@
                <div class="card-footer bg-light border-top p-4 d-flex justify-content-end gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.DanhGiaId" class="btn btn-warning px-4 py-2 rounded-pill text-white shadow-sm">
                        <i class="bi bi-pencil-square me-2"></i> Chỉnh sửa
                    </a>
                    <form asp-action="Delete" asp-route-id="@Model.DanhGiaId" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa đánh giá này?');">
                        <button type="submit" class="btn btn-danger px-4 py-2 rounded-pill shadow-sm">
                            <i class="bi bi-trash3 me-2"></i> Xóa đánh giá
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .card {
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
    }

    .bg-primary-subtle {
        background-color: #e7f1ff !important;
    }

    .bg-success-subtle {
        background-color: #d1e7dd !important;
    }

    .bg-secondary-subtle {
        background-color: #e2e3e5 !important;
    }
</style>