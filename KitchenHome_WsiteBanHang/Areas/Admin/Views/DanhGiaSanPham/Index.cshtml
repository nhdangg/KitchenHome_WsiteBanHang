@model IEnumerable<KitchenHome_WsiteBanHang.Models.DanhGiaSanPham>

@{
    ViewData["Title"] = "Quản lý đánh giá sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-primary text-uppercase mb-0">
        <i class="bi bi-chat-left-text me-2"></i>Quản lý đánh giá
    </h3>
    <a asp-action="Create" class="btn btn-primary px-3 shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> Thêm mới
    </a>
</div>

<div class="card border-0 shadow-sm mb-4 bg-light">
    <div class="card-body p-3">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control border-start-0" placeholder="Tìm theo tên SP hoặc khách hàng..." />
                </div>
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-filter me-1"></i> Lọc
                </button>
            </div>
            <div class="col-md-auto ms-auto">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-clockwise"></i> Reset
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-3 py-3" width="50">#</th>
                        <th>Sản phẩm</th>
                        <th>Khách hàng</th>
                        <th class="text-center">Đánh giá</th>
                        <th>Nội dung</th>
                        <th>Ngày tạo</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int stt = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-bold text-muted">@stt</td>
                            <td>
                                <div class="fw-bold text-primary">@item.SanPham?.TenSanPham</div>
                                <div class="text-muted small">ID: @item.SanPhamId</div>
                            </td>
                            <td>
                                <div class="fw-bold">@(item.KhachHang?.HoTen ?? "Khách vãng lai")</div>
                                <div class="text-muted small"><i class="bi bi-telephone me-1"></i>@item.KhachHang?.SoDienThoai</div>
                            </td>
                            <td class="text-center">
                                <div class="text-warning small">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi bi-star-fill @(i <= item.SoSao ? "" : "text-secondary opacity-25")"></i>
                                    }
                                </div>
                                <span class="badge bg-light text-dark border fw-normal mt-1">@item.SoSao/5</span>
                            </td>
                            <td>
                                <div class="fw-bold text-truncate" style="max-width: 180px;">@item.TieuDe</div>
                                <div class="small text-muted text-truncate" style="max-width: 180px;">@item.NoiDung</div>
                            </td>
                            <td class="small text-muted">
                                <div><i class="bi bi-calendar3 me-1"></i>@item.NgayTao.ToString("dd/MM/yyyy")</div>
                                <div><i class="bi bi-clock me-1"></i>@item.NgayTao.ToString("HH:mm")</div>
                            </td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input cursor-pointer" type="checkbox" role="switch"
                                           @(item.HienThi ? "checked" : "")
                                           onclick="toggleHienThi(@item.DanhGiaId)">
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Details" asp-route-id="@item.DanhGiaId" class="btn btn-sm btn-outline-info rounded-circle" title="Xem">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.DanhGiaId" class="btn btn-sm btn-outline-warning rounded-circle" title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.DanhGiaId" method="post" class="d-inline" onsubmit="return confirm('Xóa đánh giá này?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        stt++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleHienThi(id) {
            fetch('/Admin/DanhGiaSanPham/ToggleHienThi?id=' + id, {
                method: 'POST'
            }).then(r => {
                if (!r.ok) {
                    alert("Cập nhật thất bại!");
                    location.reload();
                }
            });
        }
    </script>
}

<style>
    .cursor-pointer {
        cursor: pointer;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.02);
    }
    /* Style cho nút Thao tác hình tròn đồng bộ với Danh mục */
    .btn-sm.rounded-circle {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }
</style>