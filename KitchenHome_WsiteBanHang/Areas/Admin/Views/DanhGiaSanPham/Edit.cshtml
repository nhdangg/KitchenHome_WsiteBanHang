@model KitchenHome_WsiteBanHang.Models.DanhGiaSanPham

@{
    ViewData["Title"] = "Chỉnh sửa đánh giá";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .input-validation-error {
        border: 1px solid #dc3545 !important;
        background-color: rgba(220, 53, 69, 0.02);
    }

    .field-validation-error {
        font-size: 0.85rem;
        color: #dc3545;
        margin-top: 4px;
        display: block;
    }

    .star-item:hover {
        transform: scale(1.2);
        transition: 0.15s;
        cursor: pointer;
    }

    .card {
        border-radius: 12px;
    }
</style>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary text-uppercase mb-0">
            <i class="bi bi-pencil-square me-2"></i>Chỉnh sửa đánh giá
        </h3>
        <a asp-action="Index" class="btn btn-outline-secondary px-3 shadow-sm rounded-pill">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" id="editForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="DanhGiaId" />

                        @* Thông tin tham chiếu (Read-only) *@
                        <div class="mb-4 p-3 bg-light rounded-3 border">
                            <div class="row">
                                <div class="col-sm-6">
                                    <label class="text-secondary small fw-bold text-uppercase">Khách hàng</label>
                                    <p class="fw-bold text-dark mb-0">@(Model.KhachHang?.HoTen ?? "Khách vãng lai")</p>
                                </div>
                                <div class="col-sm-6 text-sm-end">
                                    <label class="text-secondary small fw-bold text-uppercase">Sản phẩm</label>
                                    <p class="text-primary fw-bold mb-0">@Model.SanPham?.TenSanPham</p>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mức độ đánh giá</label>
                            <div class="star-rating fs-2 text-warning">
                                <input asp-for="SoSao" type="hidden" id="inputSoSao" />
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= Model.SoSao ? "bi-star-fill" : "bi-star") star-item" data-value="@i"></i>
                                }
                            </div>
                            <span asp-validation-for="SoSao"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TieuDe" class="form-label fw-bold">Tiêu đề đánh giá</label>
                            <input asp-for="TieuDe" class="form-control shadow-none" placeholder="Nhập tiêu đề..." />
                            <span asp-validation-for="TieuDe"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NoiDung" class="form-label fw-bold">Nội dung phản hồi</label>
                            <textarea asp-for="NoiDung" class="form-control shadow-none" rows="5" placeholder="Nhập nội dung chi tiết..."></textarea>
                            <span asp-validation-for="NoiDung"></span>
                        </div>

                        <div class="mb-4 mt-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch" asp-for="HienThi" id="switchHienThi">
                                <label class="form-check-label fw-bold ms-2" for="switchHienThi">Hiển thị trên website</label>
                            </div>
                        </div>

                        <hr class="my-4 text-muted opacity-25">

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light px-4 rounded-pill">Hủy</a>
                            <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm fw-bold">
                                <i class="bi bi-cloud-arrow-up me-1"></i> Cập nhật thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            $('.star-item').click(function () {
                const val = $(this).data('value');
                $('#inputSoSao').val(val);

                $('.star-item').each(function () {
                    const itemVal = $(this).data('value');
                    if (itemVal <= val) {
                        $(this).removeClass('bi-star').addClass('bi-star-fill');
                    } else {
                        $(this).removeClass('bi-star-fill').addClass('bi-star');
                    }
                });
            });
        });
    </script>
}