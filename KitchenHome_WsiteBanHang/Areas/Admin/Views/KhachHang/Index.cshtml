@model IEnumerable<KitchenHome_WsiteBanHang.Models.KhachHang>

@{
    ViewData["Title"] = "Quản lý khách hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold text-primary text-uppercase mb-0">
            <i class="bi bi-people-fill me-2"></i>Danh sách khách hàng
        </h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Admin</a></li>
                <li class="breadcrumb-item active">Khách hàng</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" class="row g-3 align-items-center">
            <div class="col-md-6 col-lg-5">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="searchString" value="@ViewContext.HttpContext.Request.Query["searchString"]"
                           class="form-control bg-light border-start-0"
                           placeholder="Nhập tên, số điện thoại, mã khách hàng..." />
                </div>
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-filter me-1"></i> Tìm kiếm
                </button>
            </div>
            <div class="col-md-auto ms-auto">
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-clockwise"></i> Reset
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-3 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small fw-bold text-uppercase">
                    <tr>
                        <th class="ps-4 py-3" width="10%">Mã KH</th>
                        <th width="20%">Họ tên</th>
                        <th width="25%">Liên hệ</th>
                        <th width="15%">Loại tài khoản</th>
                        <th class="text-center" width="10%">Trạng thái</th>
                        <th class="text-end pe-4" width="20%">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">#@item.MaKhachHang</td>
                                <td>
                                    <div class="fw-bold text-primary">@item.HoTen</div>
                                    <small class="badge bg-light text-dark border fw-normal">@item.GioiTinh</small>
                                </td>
                                <td>
                                    <div class="small mb-1">
                                        <i class="bi bi-telephone text-muted me-2"></i>@item.SoDienThoai
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.Email))
                                    {
                                        <div class="small text-muted">
                                            <i class="bi bi-envelope text-muted me-2"></i>@item.Email
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (item.TaiKhoanId != null)
                                    {
                                        <span class="badge bg-success-subtle text-success px-2 py-1 mb-1">
                                            <i class="bi bi-person-check-fill me-1"></i>Đã đăng ký
                                        </span>
                                        <div class="x-small text-muted" style="font-size: 0.75rem;">
                                            User: @item.TaiKhoan?.TenDangNhap
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary px-2 py-1">
                                            <i class="bi bi-person-dash me-1"></i>Khách vãng lai
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.DangHoatDong)
                                    {
                                        <span class="text-success fs-5" title="Đang hoạt động">
                                            <i class="bi bi-check-circle-fill"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fs-5" title="Bị khóa">
                                            <i class="bi bi-x-circle-fill"></i>
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm rounded overflow-hidden">
                                        <a href="@Url.Action("Details", new { id = item.KhachHangId })"
                                           class="btn btn-sm btn-white border" title="Xem chi tiết">
                                            <i class="bi bi-eye text-info"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = item.KhachHangId })"
                                           class="btn btn-sm btn-white border" title="Chỉnh sửa">
                                            <i class="bi bi-pencil-square text-warning"></i>
                                        </a>
                                        <form action="@Url.Action("Delete", new { id = item.KhachHangId })"
                                              method="post" class="d-inline"
                                              onsubmit="return confirm('Xác nhận xóa khách hàng @item.HoTen?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-white border" title="Xóa">
                                                <i class="bi bi-trash text-danger"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="text-muted">
                                    <i class="bi bi-people fs-1 opacity-25 d-block mb-3"></i>
                                    Không có dữ liệu khách hàng nào.
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @* --- PHẦN PHÂN TRANG ĐỒNG BỘ GIAO DIỆN --- *@
        @if (ViewBag.TotalPages > 1)
        {
            <div class="card-footer bg-white border-top-0 py-3">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm justify-content-center mb-0">

                        @* Nút Quay lại *@
                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link border-0 shadow-sm mx-1 rounded text-primary"
                               href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1, searchString = ViewBag.SearchString })">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @* Danh sách số trang *@
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                <a class="page-link border-0 shadow-sm mx-1 rounded @(ViewBag.CurrentPage == i ? "bg-primary text-white" : "text-dark bg-light")"
                                   href="@Url.Action("Index", new { page = i, searchString = ViewBag.SearchString })">@i</a>
                            </li>
                        }

                        @* Nút Tiếp theo *@
                        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link border-0 shadow-sm mx-1 rounded text-primary"
                               href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1, searchString = ViewBag.SearchString })">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
                <div class="text-center mt-2 small text-muted">
                    Trang @ViewBag.CurrentPage / @ViewBag.TotalPages
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* CSS bổ trợ để đồng bộ */
    .bg-success-subtle {
        background-color: #e8f5e9 !important;
        color: #2e7d32 !important;
    }

    .bg-secondary-subtle {
        background-color: #f5f5f5 !important;
        color: #616161 !important;
    }

    .btn-white {
        background-color: #fff;
    }

        .btn-white:hover {
            background-color: #f8f9fa;
        }

    .table thead th {
        font-size: 0.75rem;
        letter-spacing: 0.05rem;
    }

    .btn-group .btn {
        padding: 0.4rem 0.6rem;
    }

    .pagination .page-link {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }

        .pagination .page-link:hover:not(.active) {
            background-color: #e9ecef !important;
            transform: translateY(-2px);
        }

    .pagination .page-item.active .page-link {
        box-shadow: 0 4px 10px rgba(13, 110, 253, 0.2) !important;
    }

    .pagination .page-item.disabled .page-link {
        opacity: 0.5;
        background-color: #f8f9fa !important;
    }
</style>