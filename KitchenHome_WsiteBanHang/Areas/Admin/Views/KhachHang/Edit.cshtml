@model KitchenHome_WsiteBanHang.Models.KhachHang

@{
    ViewData["Title"] = "Cập nhật khách hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-primary text-uppercase mb-0">
                <i class="bi bi-person-gear me-2"></i>Cập nhật thông tin khách hàng
            </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Admin</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index")">Khách hàng</a></li>
                    <li class="breadcrumb-item active">Chỉnh sửa</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm px-3 rounded-pill">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 border-bottom">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary-subtle p-2 rounded-3 me-3">
                            <i class="bi bi-pencil-square text-primary"></i>
                        </div>
                        <div>
                            <h5 class="card-title mb-0 fw-bold text-dark">Mã khách hàng: #@Model.MaKhachHang</h5>
                            <small class="text-muted">Chỉnh sửa thông tin chi tiết và trạng thái hoạt động</small>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="KhachHangId" />
                        <input type="hidden" asp-for="MaKhachHang" />
                        <input type="hidden" asp-for="TaiKhoanId" />
                        <input type="hidden" asp-for="NgayTao" />

                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Họ và tên <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-muted"></i></span>
                                    <input asp-for="HoTen" class="form-control border-start-0 ps-0" required placeholder="Nhập họ tên đầy đủ..." />
                                </div>
                                <span asp-validation-for="HoTen" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Số điện thoại <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-telephone text-muted"></i></span>
                                    <input asp-for="SoDienThoai" class="form-control border-start-0 ps-0" required placeholder="Nhập số điện thoại..." />
                                </div>
                                <span asp-validation-for="SoDienThoai" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Email</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                                    <input asp-for="Email" type="email" class="form-control border-start-0 ps-0" placeholder="example@gmail.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Giới tính</label>
                                <select asp-for="GioiTinh" class="form-select bg-light">
                                    <option value="">-- Chọn giới tính --</option>
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                    <option value="Khác">Khác</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Ngày sinh</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-calendar-event text-muted"></i></span>
                                    <input asp-for="NgaySinh" type="date" class="form-control border-start-0 ps-0" />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Ghi chú (Nội bộ Admin)</label>
                                <textarea asp-for="GhiChu" class="form-control bg-light" rows="1" placeholder="Lưu ý về khách hàng..."></textarea>
                            </div>
                        </div>

                        <div class="bg-light rounded-3 p-3 mb-4 border">
                            <div class="form-check form-switch mb-0">
                                <input asp-for="DangHoatDong" class="form-check-input" type="checkbox" id="flexSwitchCheckDefault">
                                <label class="form-check-label fw-bold text-dark ms-2" for="flexSwitchCheckDefault">
                                    Trạng thái hoạt động
                                </label>
                                <div class="form-text mt-1 ms-2">Cho phép khách hàng đăng nhập và đặt hàng trên hệ thống.</div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 pt-2 border-top">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm">
                                <i class="bi bi-save me-2"></i>Lưu thay đổi
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4 border">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* CSS đồng bộ giao diện */
    .bg-primary-subtle {
        background-color: #e7f1ff !important;
    }

    .input-group-text {
        border-color: #dee2e6;
    }

    .form-control:focus, .form-select:focus {
        border-color: #0d6efd;
        box-shadow: none;
    }

    .form-check-input:checked {
        background-color: #198754;
        border-color: #198754;
    }
    /* Breadcrumb styling */
    .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
        font-size: 1.2rem;
        line-height: 1;
        vertical-align: middle;
    }
</style>