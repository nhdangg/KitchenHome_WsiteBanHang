@model KitchenHome_WsiteBanHang.Models.TaiKhoan

@{
    ViewData["Title"] = "Thêm tài khoản";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-user-plus me-2"></i>Tạo tài khoản hệ thống</h5>
                </div>
                <div class="card-body p-4">

                    <div asp-validation-summary="All" class="alert alert-danger shadow-sm border-start border-4 border-danger animate__animated animate__shakeX">
                        <h6 class="fw-bold"><i class="fas fa-exclamation-circle me-2"></i>Vui lòng sửa các lỗi sau:</h6>
                    </div>

                    <form asp-action="Create" method="post">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="TenDangNhap" class="form-label fw-bold">Tên đăng nhập</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fas fa-user"></i></span>
                                    <input asp-for="TenDangNhap" class="form-control" placeholder="Ví dụ: admin_ketoan" required />
                                </div>
                                <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Mật khẩu khởi tạo</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fas fa-key"></i></span>
                                    <input name="MatKhauRaw" type="password" class="form-control" placeholder="••••••••" required />
                                </div>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Email" class="form-label fw-bold">Địa chỉ Email</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fas fa-envelope"></i></span>
                                    <input asp-for="Email" class="form-control" placeholder="user@kitchenhome.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-bold">Phân quyền vai trò</label>
                                <select name="selectedRoles" asp-items="ViewBag.VaiTros" multiple class="form-select border-primary shadow-none" style="height: 120px;"></select>
                                <div class="form-text text-info"><i class="fas fa-info-circle me-1"></i>Giữ phím <b>Ctrl</b> để chọn nhiều vai trò cùng lúc.</div>
                            </div>

                            <div class="col-md-12 mt-4">
                                <div class="form-check form-switch p-3 bg-light rounded border border-dashed shadow-sm">
                                    <input asp-for="DangHoatDong" class="form-check-input ms-0 me-3" type="checkbox" role="switch" id="activeSwitch" checked>
                                    <label class="form-check-label fw-bold" for="activeSwitch">Kích hoạt tài khoản ngay lập tức</label>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="fas fa-times me-1"></i> Hủy bỏ</a>
                            <button type="submit" class="btn btn-primary px-5 shadow-sm fw-bold">
                                <i class="fas fa-save me-1"></i> Xác nhận tạo tài khoản
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Ẩn validation summary nếu không có lỗi */
    .validation-summary-valid {
        display: none;
    }

    .form-control:focus, .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
    }

    .border-dashed {
        border-style: dashed !important;
    }
</style>