@model IEnumerable<KitchenHome_WsiteBanHang.Models.TaiKhoan>

@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<div class="container-fluid px-4">
    <div class="d-flex align-items-center justify-content-between mb-4 mt-3">
        <h3 class="fw-bold text-primary"><i class="fas fa-users-cog me-2"></i>Danh sách tài khoản</h3>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus-circle me-1"></i> Thêm mới
        </a>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase fs-7 fw-bold">Tài khoản</th>
                            <th class="py-3 text-uppercase fs-7 fw-bold">Email / SĐT</th>
                            <th class="py-3 text-uppercase fs-7 fw-bold">Vai trò</th>
                            <th class="py-3 text-uppercase fs-7 fw-bold text-center">Trạng thái</th>
                            <th class="py-3 text-uppercase fs-7 fw-bold text-center" width="150">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm me-3 bg-soft-primary text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 38px; height: 38px; background-color: #e7f1ff;">
                                            <i class="fas fa-user border border-primary rounded-circle p-1"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@item.TenDangNhap</div>
                                            <small class="text-muted">ID: #@item.TaiKhoanId</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small"><i class="fas fa-envelope me-1 text-muted"></i>@item.Email</div>
                                    <div class="small"><i class="fas fa-phone me-1 text-muted"></i>@item.SoDienThoai</div>
                                </td>
                                <td>
                                    @foreach (var role in item.VaiTros)
                                    {
                                        <span class="badge rounded-pill bg-info text-dark fw-normal px-2 me-1" style="font-size: 0.7rem;">
                                            @role.TenVaiTro
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.DangHoatDong)
                                    {
                                        <span class="badge bg-soft-success text-success px-3 py-2">
                                            <i class="fas fa-check-circle me-1"></i> Online
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-soft-danger text-danger px-3 py-2">
                                            <i class="fas fa-ban me-1"></i> Khóa
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.TaiKhoanId" class="btn btn-outline-warning btn-sm border-0" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.TaiKhoanId" class="btn btn-outline-danger btn-sm border-0" title="Xóa">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .fs-7 {
        font-size: 0.75rem;
    }

    .bg-soft-success {
        background-color: #d1e7dd;
        color: #0f5132;
    }

    .bg-soft-danger {
        background-color: #f8d7da;
        color: #842029;
    }

    .table-hover tbody tr:hover {
        background-color: #f8faff !important;
    }
</style>