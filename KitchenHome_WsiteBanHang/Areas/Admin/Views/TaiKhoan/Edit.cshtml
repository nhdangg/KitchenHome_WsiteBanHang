@model KitchenHome_WsiteBanHang.Models.TaiKhoan

@{
    ViewData["Title"] = "Sửa tài khoản";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0 rounded-3">
                <div asp-validation-summary="All" class="alert alert-danger shadow-sm border-start border-4 border-danger">
                    <h6 class="fw-bold"><i class="fas fa-exclamation-circle me-2"></i>Có lỗi xảy ra:</h6>
                </div>
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Cập nhật thông tin: @Model.TenDangNhap</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="TaiKhoanId" />

                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted">Tên đăng nhập (Cố định)</label>
                            <input asp-for="TenDangNhap" class="form-control bg-light" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Email liên hệ</label>
                            <input asp-for="Email" class="form-control" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Phân quyền hệ thống</label>
                            <select name="selectedRoles" asp-items="ViewBag.VaiTros" multiple class="form-select border-primary" style="height: 100px;"></select>
                            <small class="text-info"><i class="fas fa-info-circle me-1"></i>Thay đổi vai trò sẽ ảnh hưởng đến quyền truy cập.</small>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input asp-for="DangHoatDong" class="form-check-input" type="checkbox">
                            <label class="form-check-label">Đang hoạt động</label>
                        </div>

                        <div class="d-flex justify-content-between border-top pt-3">
                            <a asp-action="Index" class="btn btn-link text-decoration-none text-muted"><i class="fas fa-chevron-left me-1"></i> Quay về</a>
                            <button type="submit" class="btn btn-warning px-4 fw-bold">Lưu thay đổi</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>