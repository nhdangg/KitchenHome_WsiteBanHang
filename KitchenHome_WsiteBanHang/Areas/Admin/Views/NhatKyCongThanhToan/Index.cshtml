@model IEnumerable<KitchenHome_WsiteBanHang.Models.NhatKyCongThanhToan>

@{
    ViewData["Title"] = "Nhật ký cổng thanh toán";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@* --- Tiêu đề và Breadcrumb --- *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold text-primary text-uppercase mb-0">
            <i class="bi bi-journal-text me-2"></i>Nhật ký cổng thanh toán
        </h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Admin</a></li>
                <li class="breadcrumb-item active">Nhật ký thanh toán</li>
            </ol>
        </nav>
    </div>
</div>


@* --- Bảng dữ liệu --- *@
<div class="card shadow-sm border-0 rounded-3 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small fw-bold text-uppercase">
                    <tr>
                        <th class="ps-4 py-3" width="5%">#</th>
                        <th width="15%">Cổng thanh toán</th>
                        <th width="15%">Mã đơn hàng</th>
                        <th width="15%">Số tiền</th>
                        <th width="15%">Mã kết quả</th>
                        <th width="15%">Ngày tạo</th>
                        <th class="text-end pe-4" width="10%">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int stt = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted">@stt</td>
                                <td>
                                    <span class="badge bg-primary-subtle text-primary px-2 py-1">
                                        <i class="bi bi-credit-card-2-back me-1"></i>@item.CongThanhToan
                                    </span>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">#@item.ThanhToan?.DonHang?.MaDonHang</div>
                                    <small class="text-muted">ID: @item.ThanhToan?.PhuongThucId</small>
                                </td>
                                <td class="fw-bold text-danger">
                                    @item.ThanhToan?.SoTien.ToString("N0") <small>₫</small>
                                </td>
                                <td>
                                    @if (string.IsNullOrEmpty(item.MaKetQua) || item.MaKetQua != "00")
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary px-2 py-1">
                                            <i class="bi bi-exclamation-circle me-1"></i>@(item.MaKetQua ?? "N/A")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success px-2 py-1">
                                            <i class="bi bi-check-circle-fill me-1"></i>Thành công
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="small">@item.NgayTao.ToString("dd/MM/yyyy")</div>
                                    <div class="x-small text-muted" style="font-size: 0.75rem;">@item.NgayTao.ToString("HH:mm:ss")</div>
                                </td>
                                <td class="text-end pe-4">
                                    <a href="@Url.Action("Details", new { id = item.NhatKyId })"
                                       class="btn btn-sm btn-white border shadow-sm" title="Chi tiết">
                                        <i class="bi bi-eye text-info"></i>
                                    </a>
                                </td>
                            </tr>
                            stt++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <div class="text-muted">
                                    <i class="bi bi- receipt fs-1 opacity-25 d-block mb-3"></i>
                                    Chưa có nhật ký giao dịch nào.
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* CSS đồng bộ bộ nhận diện */
    .bg-success-subtle {
        background-color: #e8f5e9 !important;
        color: #2e7d32 !important;
    }

    .bg-primary-subtle {
        background-color: #e3f2fd !important;
        color: #0d6efd !important;
    }

    .bg-secondary-subtle {
        background-color: #f5f5f5 !important;
        color: #616161 !important;
    }

    .btn-white {
        background-color: #fff;
    }

        .btn-white:hover {
            background-color: #f8f9fa;
        }

    .table thead th {
        font-size: 0.75rem;
        letter-spacing: 0.05rem;
    }
</style>