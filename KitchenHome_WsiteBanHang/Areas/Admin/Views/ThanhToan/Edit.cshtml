@model KitchenHome_WsiteBanHang.Models.ThanhToan

@{
    ViewData["Title"] = "Cập nhật thanh toán";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow border-0 border-top border-warning border-3 rounded-3">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-warning text-uppercase"><i class="bi bi-pencil-square me-2"></i>Cập nhật trạng thái</h5>
                </div>
                <div class="card-body p-4">

                    @* --- [MỚI] KHỐI HIỂN THỊ THÔNG BÁO TỪ CONTROLLER --- *@
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show mb-3 border-0 border-start border-danger border-4">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="ThanhToanId" />
                        <input type="hidden" asp-for="NgayTao" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        @* Thông tin không sửa được *@
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">Đơn hàng</label>
                                <select asp-for="DonHangId" class="form-select bg-light" asp-items="ViewBag.DonHangId" disabled></select>
                                <input type="hidden" asp-for="DonHangId" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">Phương thức</label>
                                <select asp-for="PhuongThucId" class="form-select bg-light" asp-items="ViewBag.PhuongThucId" disabled></select>
                                <input type="hidden" asp-for="PhuongThucId" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SoTien" class="form-label fw-bold">Số tiền (VNĐ) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="SoTien" class="form-control text-end fw-bold" type="number" />
                                <span class="input-group-text">₫</span>
                            </div>
                            <span asp-validation-for="SoTien" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MaGiaoDich" class="form-label fw-bold">Mã giao dịch</label>
                            <input asp-for="MaGiaoDich" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="NgayThanhToan" class="form-label fw-bold">Ngày hoàn tất (Thực tế)</label>
                            <input asp-for="NgayThanhToan" class="form-control" type="datetime-local" />
                        </div>

                        <div class="mb-4">
                            <label asp-for="TrangThai" class="form-label fw-bold">Trạng thái <span class="text-danger">*</span></label>
                            <select asp-for="TrangThai" class="form-select form-select-lg fw-bold border-warning text-dark" asp-items="ViewBag.TrangThaiList"></select>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-action="Index" class="btn btn-secondary px-4 shadow-sm">Quay lại</a>
                            <button type="submit" class="btn btn-warning px-4 fw-bold shadow-sm"><i class="bi bi-check-lg me-1"></i> Cập nhật</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}