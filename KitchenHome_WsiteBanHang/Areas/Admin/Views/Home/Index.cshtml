@{
    ViewData["Title"] = "Bảng điều khiển quản trị";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4">
    <h3 class="fw-bold text-primary text-uppercase mb-4 pt-3">
        <i class="bi bi-speedometer2 me-2"></i>Báo cáo hệ thống
    </h3>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="flex-shrink-0 bg-primary-subtle text-primary rounded-circle p-3 me-3">
                        <i class="bi bi-cart-check fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block">Tổng đơn hàng</small>
                        <h4 class="fw-bold mb-0">@ViewBag.TongDonHang</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="flex-shrink-0 bg-success-subtle text-success rounded-circle p-3 me-3">
                        <i class="bi bi-cash-stack fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block">Tổng doanh thu</small>
                        <h4 class="fw-bold text-success mb-0">@String.Format("{0:N0} đ", ViewBag.DoanhThu)</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="flex-shrink-0 bg-info-subtle text-info rounded-circle p-3 me-3">
                        <i class="bi bi-people fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block">Khách hàng</small>
                        <h4 class="fw-bold mb-0">@ViewBag.TongKhachHang</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="flex-shrink-0 bg-warning-subtle text-warning rounded-circle p-3 me-3">
                        <i class="bi bi-box-seam fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block">Sản phẩm</small>
                        <h4 class="fw-bold mb-0">@ViewBag.TongSanPham</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 border-start border-danger border-4 shadow-sm bg-white">
                <div class="card-body py-3">
                    <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Tổng tiền hoàn</small>
                    <h5 class="text-danger fw-bold mb-0">@String.Format("{0:N0} đ", ViewBag.TongTienHoan)</h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 border-start border-warning border-4 shadow-sm bg-white">
                <div class="card-body py-3">
                    <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Tiền chờ hoàn</small>
                    <h5 class="text-warning fw-bold mb-0">@String.Format("{0:N0} đ", ViewBag.TienChoHoan)</h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 border-start border-info border-4 shadow-sm bg-white">
                <div class="card-body py-3">
                    <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Số lượt hoàn</small>
                    <h5 class="text-info fw-bold mb-0">@ViewBag.SoLuotHoan</h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 border-start border-success border-4 shadow-sm bg-white">
                <div class="card-body py-3">
                    <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Hoàn hôm nay</small>
                    <h5 class="text-success fw-bold mb-0">@String.Format("{0:N0} đ", ViewBag.HoanTienHomNay)</h5>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3 h-100">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="m-0 fw-bold text-dark"><i class="bi bi-graph-up-arrow me-2"></i>Biểu đồ doanh thu</h6>
                </div>
                <div class="card-body">
                    <canvas id="revenueChart" style="max-height: 350px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3 h-100">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="m-0 fw-bold text-dark"><i class="bi bi-pie-chart-fill me-2"></i>Tỷ lệ trạng thái</h6>
                </div>
                <div class="card-body d-flex align-items-center">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header bg-white py-3 border-0">
            <h6 class="m-0 fw-bold text-dark"><i class="bi bi-clock-history me-2"></i>Lịch sử hoàn tiền gần đây</h6>
        </div>
        <div class="card-body">
            <canvas id="refundChart" style="max-height: 250px;"></canvas>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 mb-5 overflow-hidden">
        <div class="card-header bg-primary py-3">
            <h6 class="m-0 fw-bold text-white"><i class="bi bi-lightning-fill me-2"></i>Đơn hàng mới nhận</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small fw-bold text-uppercase">
                        <tr>
                            <th class="ps-4 py-3">Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Tổng cộng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in ViewBag.DonHangMoi)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-primary">#@d.MaDonHang</td>
                                <td>@d.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <span class="badge bg-primary-subtle text-primary px-3 py-2">@d.TrangThai</span>
                                </td>
                                <td class="text-end pe-4 fw-bold">@String.Format("{0:N0} đ", d.TongTien)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* --- CSS Bổ trợ --- *@
<style>
    .bg-primary-subtle {
        background-color: #e7f1ff !important;
    }

    .bg-success-subtle {
        background-color: #e6fffa !important;
    }

    .bg-info-subtle {
        background-color: #e1f5fe !important;
    }

    .bg-warning-subtle {
        background-color: #fff9db !important;
    }

    .card {
        transition: transform 0.2s ease;
    }

        .card:hover {
            transform: translateY(-3px);
        }

    .table thead th {
        font-size: 0.75rem;
        letter-spacing: 0.05rem;
    }
</style>

@* --- SCRIPT GIỮ NGUYÊN LOGIC --- *@
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const chartOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { position: 'bottom' }
        }
    };

    new Chart(document.getElementById('revenueChart'), {
        type: 'line',
        data: {
            labels: @Html.Raw(ViewBag.ChartLabels),
            datasets: [{
                label: 'Doanh thu (VNĐ)',
                data: @Html.Raw(ViewBag.ChartData),
                borderColor: '#0d6efd',
                backgroundColor: 'rgba(13, 110, 253, 0.1)',
                fill: true,
                tension: 0.4
            }]
        },
        options: chartOptions
    });

    new Chart(document.getElementById('refundChart'), {
        type: 'bar', // Đổi sang Bar nhìn sẽ khác biệt so với Revenue
        data: {
            labels: @Html.Raw(ViewBag.RefundLabels),
            datasets: [{
                label: 'Hoàn tiền',
                data: @Html.Raw(ViewBag.RefundData),
                backgroundColor: '#dc3545',
                borderRadius: 5
            }]
        },
        options: chartOptions
    });

    new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
            labels: @Html.Raw(ViewBag.StatusLabels),
            datasets: [{
                data: @Html.Raw(ViewBag.StatusData),
                backgroundColor: ['#0d6efd', '#198754', '#ffc107', '#dc3545', '#6c757d']
            }]
        },
        options: {
            plugins: {
                legend: { position: 'right' }
            }
        }
    });
</script>