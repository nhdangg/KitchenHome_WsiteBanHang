@model KitchenHome_WsiteBanHang.Models.SanPham

@{
    ViewData["Title"] = "Thêm mới sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-primary text-uppercase"><i class="bi bi-plus-circle me-2"></i>Thêm sản phẩm mới</h3>
    <a asp-action="Index" class="btn btn-secondary shadow-sm">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

<div class="card shadow border-0 rounded-3">
    <div class="card-body p-4">
        @* Form Upload file cần enctype *@
        <form asp-area="Admin"
              asp-controller="SanPham"
              asp-action="Create"
              method="post"
              enctype="multipart/form-data">

            @* AntiForgeryToken tự động *@
            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 border-start border-danger border-4 shadow-sm"></div>

            <div class="row">
                @* --- CỘT TRÁI: THÔNG TIN CHI TIẾT --- *@
                <div class="col-md-8">
                    <div class="mb-3">
                        <label asp-for="TenSanPham" class="form-label fw-bold">Tên sản phẩm <span class="text-danger">*</span></label>
                        <input asp-for="TenSanPham" class="form-control" placeholder="Nhập tên sản phẩm..." required />
                        <span asp-validation-for="TenSanPham" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="MaSanPham" class="form-label fw-bold">Mã sản phẩm <span class="text-muted fw-normal">(Tự động nếu để trống)</span></label>
                            <input asp-for="MaSanPham" class="form-control" placeholder="VD: SP001" />
                            <span asp-validation-for="MaSanPham" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DonViTinhId" class="form-label fw-bold">Đơn vị tính</label>
                            <select asp-for="DonViTinhId" class="form-select" asp-items="ViewBag.DonViTinhId">
                                <option value="">-- Chọn đơn vị --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DanhMucId" class="form-label fw-bold">Danh mục <span class="text-danger">*</span></label>
                            <select asp-for="DanhMucId" class="form-select" asp-items="ViewBag.DanhMucId" required>
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                            <span asp-validation-for="DanhMucId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ThuongHieuId" class="form-label fw-bold">Thương hiệu</label>
                            <select asp-for="ThuongHieuId" class="form-select" asp-items="ViewBag.ThuongHieuId">
                                <option value="">-- Chọn thương hiệu --</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MoTaNgan" class="form-label fw-bold">Mô tả ngắn</label>
                        <textarea asp-for="MoTaNgan" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="MoTaNgan" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MoTaChiTiet" class="form-label fw-bold">Mô tả chi tiết</label>
                        <textarea asp-for="MoTaChiTiet" class="form-control" rows="8" id="editor"></textarea>
                        <div class="form-text text-muted"><i class="bi bi-info-circle"></i> Có thể tích hợp trình soạn thảo (CKEditor) tại đây.</div>
                        <span asp-validation-for="MoTaChiTiet" class="text-danger small"></span>
                    </div>
                </div>

                @* --- CỘT PHẢI: ẢNH & CẤU HÌNH --- *@
                <div class="col-md-4">
                    @* Card Ảnh *@
                    <div class="card bg-light border-0 mb-3 rounded-3">
                        <div class="card-body">
                            <label class="form-label fw-bold mb-2">Ảnh đại diện</label>
                            <input type="file" name="ImageFile" class="form-control mb-2" onchange="previewImage(this)" accept="image/*" />

                            <div class="text-center bg-white p-2 border rounded shadow-sm" style="min-height: 200px; display: flex; align-items: center; justify-content: center;">
                                <img id="preview" src="#" alt="Preview Image" class="img-fluid d-none" style="max-height: 200px; object-fit: contain;" />
                                <span id="preview-placeholder" class="text-muted small">Chưa có ảnh</span>
                            </div>
                        </div>
                    </div>

                    @* Card Cấu hình *@
                    <div class="card bg-light border-0 rounded-3">
                        <div class="card-body">
                            <h6 class="fw-bold mb-3 text-uppercase text-secondary">Cài đặt hiển thị</h6>

                            <div class="form-check form-switch mb-3 ps-5">
                                <input class="form-check-input scale-125" type="checkbox" asp-for="DangHoatDong" checked />
                                <label class="form-check-label fw-bold ms-2 user-select-none" asp-for="DangHoatDong">Đang hoạt động</label>
                            </div>

                            <div class="form-check form-switch mb-3 ps-5">
                                <input class="form-check-input scale-125" type="checkbox" asp-for="HienThiTrangChu" />
                                <label class="form-check-label fw-bold ms-2 user-select-none" asp-for="HienThiTrangChu">Hiển thị trang chủ</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm fw-bold">
                            <i class="bi bi-save me-2"></i> Lưu sản phẩm
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function previewImage(input) {
            var preview = document.getElementById('preview');
            var placeholder = document.getElementById('preview-placeholder');

            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.classList.remove('d-none'); // Hiện ảnh
                    if(placeholder) placeholder.classList.add('d-none'); // Ẩn chữ placeholder
                }
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.src = '#';
                preview.classList.add('d-none');
                if(placeholder) placeholder.classList.remove('d-none');
            }
        }
    </script>

    <style>
        .scale-125 {
            transform: scale(1.25);
        }
        /* Phóng to checkbox switch một chút cho đẹp */
    </style>
}