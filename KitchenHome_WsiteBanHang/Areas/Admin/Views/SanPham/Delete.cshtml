@model KitchenHome_WsiteBanHang.Models.SanPham

@{
    ViewData["Title"] = "Xóa sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5" style="max-width: 600px;">
    <div class="card border-danger shadow border-0 rounded-3">
        <div class="card-header bg-danger text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i> Xác nhận xóa</h5>
        </div>
        <div class="card-body text-center p-4">
            <h5 class="card-title mt-2 fw-bold text-dark">Bạn có chắc chắn muốn xóa sản phẩm này?</h5>
            <p class="text-muted mb-4">Hành động này không thể hoàn tác và có thể xóa các biến thể liên quan.</p>

            <div class="alert alert-light border d-inline-flex align-items-center text-start p-3 shadow-sm rounded-3" style="min-width: 320px;">
                @* Logic hiển thị ảnh *@
                @{
                    string imgUrl = Model.AnhDaiDien;
                    if (!string.IsNullOrEmpty(imgUrl) && !imgUrl.StartsWith("http") && !imgUrl.StartsWith("/"))
                    {
                        imgUrl = Url.Content("~/Image/Image_SanPham/" + imgUrl);
                    }
                }

                <img src="@imgUrl"
                     alt="@Model.TenSanPham"
                     class="rounded me-3 border"
                     style="width: 70px; height: 70px; object-fit: cover;"
                     onerror="this.src='/images/no-image.png'">

                <div>
                    <div class="fw-bold text-primary fs-5">@Model.TenSanPham</div>
                    <small class="text-muted">Mã SP: <span class="font-monospace text-dark fw-bold">@Model.MaSanPham</span></small>
                </div>
            </div>

            @* --- FORM XÓA --- *@
            <form asp-action="Delete" method="post">
                @* Input ẩn ID để bind vào Action *@
                <input type="hidden" asp-for="SanPhamId" />

                <div class="mt-4 d-flex justify-content-center gap-2">
                    <a asp-action="Index" class="btn btn-secondary px-4">Hủy bỏ</a>
                    <button type="submit" class="btn btn-danger px-4 fw-bold shadow-sm">
                        <i class="bi bi-trash-fill me-1"></i> Xóa ngay
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>