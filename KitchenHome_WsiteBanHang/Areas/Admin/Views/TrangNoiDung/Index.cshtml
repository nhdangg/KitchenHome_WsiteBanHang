@model IEnumerable<KitchenHome_WsiteBanHang.Models.TrangNoiDung>

@{
    ViewData["Title"] = "Quản lý trang nội dung";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center my-4">
        <h3 class="fw-bold text-primary text-uppercase">
            <i class="bi bi-journal-text me-2"></i>Trang nội dung (Tĩnh)
        </h3>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Thêm trang mới
        </a>
    </div>

    @* Hiển thị thông báo từ TempData (SetAlert) *@
    @if (TempData["AlertMessage"] != null)
    {
        <div class="alert @TempData["AlertType"] alert-dismissible fade show shadow-sm border-0 border-start border-4">
            <i class="bi bi-bell me-2"></i> @TempData["AlertMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow mb-4 border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Tiêu đề trang</th>
                            <th>Slug (URL)</th>
                            <th>Ngày tạo</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center" width="15%">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">@item.TieuDe</td>
                                    <td class="text-muted small font-monospace">@item.MaTrang</td>
                                    <td>@item.NgayTao.ToString("dd/MM/yyyy")</td>
                                    <td class="text-center">
                                        @if (item.DangHienThi)
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success">Hiển thị</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary">Ẩn</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            @* Chi tiết *@
                                            <a asp-action="Details" asp-route-id="@item.TrangId" class="btn btn-sm btn-info text-white rounded-circle shadow-sm" title="Xem">
                                                <i class="bi bi-eye"></i>
                                            </a>

                                            @* Sửa *@
                                            <a asp-action="Edit" asp-route-id="@item.TrangId" class="btn btn-sm btn-warning rounded-circle shadow-sm" title="Sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>

                                            @* Xóa *@
                                            <form asp-action="Delete" asp-route-id="@item.TrangId" method="post" style="display:inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa trang: @item.TieuDe?');">
                                                <button type="submit" class="btn btn-sm btn-danger rounded-circle shadow-sm" title="Xóa">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="bi bi-journal-x display-4 d-block mb-3 opacity-25"></i>
                                    Chưa có trang nội dung nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>