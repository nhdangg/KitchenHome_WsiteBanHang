@model KitchenHome_WsiteBanHang.Models.MaGiamGia

@{
    ViewBag.Title = "Cập nhật mã";
    Layout = "~/Areas/Quan_Ly/Views/Shared/_Layout.cshtml";
}

<div class="container py-3" style="max-width: 800px">
    <div class="card shadow border-0 border-top border-warning border-3">
        <div class="card-header bg-white fw-bold text-warning">
            <i class="bi bi-pencil-square"></i> Cập nhật Voucher: @Model.Code
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">

                @* --- CÁC TRƯỜNG ẨN --- *@
                @* Chỉ giữ lại những gì có trong Model *@
                <input type="hidden" asp-for="MaGiamGiaId" />
                <input type="hidden" asp-for="Code" />
                <input type="hidden" asp-for="DaDung" />

                @* ĐÃ XÓA NgayTao VÌ MODEL KHÔNG CÓ *@

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="fw-bold">Mã Code</label>
                        <input type="text" class="form-control fw-bold bg-light" asp-for="Code" readonly />
                    </div>
                    <div class="col-md-8">
                        <label class="fw-bold">Tên chương trình</label>
                        <input asp-for="TenMa" class="form-control" required />
                    </div>
                </div>

                <div class="row mb-3 bg-light p-3 rounded mx-0">
                    <div class="col-md-4">
                        <label class="fw-bold">Loại giảm</label>
                        <select asp-for="LoaiGiam" class="form-select">
                            <option value="PHAN_TRAM">Theo % (Phần trăm)</option>
                            <option value="SO_TIEN">Theo tiền mặt (VND)</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="fw-bold">Giá trị giảm</label>
                        <input asp-for="GiaTriGiam" class="form-control fw-bold text-danger" type="number" required />
                    </div>
                    <div class="col-md-4">
                        <label class="fw-bold">Giảm tối đa (Nếu là %)</label>
                        <input asp-for="GiamToiDa" class="form-control" type="number" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="fw-bold">Đơn hàng tối thiểu</label>
                        <input asp-for="DonHangToiThieu" class="form-control" type="number" />
                    </div>
                    <div class="col-md-3">
                        <label class="fw-bold">Tổng lượt dùng</label>
                        <input asp-for="GioiHanLuotDung" class="form-control" type="number" />
                    </div>
                    <div class="col-md-3">
                        <label class="fw-bold">Lượt/Khách</label>
                        <input asp-for="GioiHanMoiKhach" class="form-control" type="number" />
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="fw-bold">Bắt đầu</label>
                        <input asp-for="BatDau" class="form-control" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
                    </div>
                    <div class="col-md-6">
                        <label class="fw-bold">Kết thúc</label>
                        <input asp-for="KetThuc" class="form-control" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
                        <span asp-validation-for="KetThuc" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-check mb-4">
                    <input class="form-check-input" type="checkbox" asp-for="DangHoatDong" />
                    <label class="form-check-label fw-bold" asp-for="DangHoatDong">Kích hoạt sử dụng</label>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
                    <button type="submit" class="btn btn-warning"><i class="bi bi-save"></i> Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}