@model IEnumerable<KitchenHome_WsiteBanHang.Models.MaGiamGia>

@{
    ViewData["Title"] = "Quản lý Mã giảm giá";
    Layout = "~/Areas/Quan_Ly/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold text-primary text-uppercase mb-0">
            <i class="bi bi-ticket-perforated-fill me-2"></i>Chương trình khuyến mãi
        </h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Admin</a></li>
                <li class="breadcrumb-item active">Mã giảm giá</li>
            </ol>
        </nav>
    </div>
    <a asp-action="Create" class="btn btn-primary px-4 shadow-sm rounded-pill">
        <i class="bi bi-plus-lg me-1"></i> Tạo mã mới
    </a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" class="row g-3 align-items-center">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@ViewContext.HttpContext.Request.Query["search"]" class="form-control bg-light border-start-0" placeholder="Tìm tên chương trình hoặc mã code..." />
                </div>
            </div>
            <div class="col-md-3">
                <select name="status" class="form-select bg-light">
                    <option value="">-- Tất cả trạng thái --</option>
                    <option value="active">Đang diễn ra</option>
                    <option value="expired">Đã kết thúc</option>
                </select>
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-dark px-4">Lọc</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-3 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small fw-bold text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Mã Code</th>
                        <th>Tên chương trình</th>
                        <th>Mức giảm</th>
                        <th class="text-center">Hiệu lực</th>
                        <th class="text-center">Sử dụng</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var isExpired = item.KetThuc < DateTime.Now;
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary-subtle text-primary fw-bold px-3 py-2 rounded-3 border border-primary-subtle border-2 text-center" style="min-width: 100px; letter-spacing: 1px;">
                                            @item.Code
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.TenMa</div>
                                    <small class="text-muted">ID: #@item.MaGiamGiaId</small>
                                </td>
                                <td>
                                    @if (item.LoaiGiam == "PHAN_TRAM")
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill fw-bold">
                                            <i class="bi bi-percent me-1"></i>@item.GiaTriGiam.ToString("N0")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill fw-bold">
                                            @item.GiaTriGiam.ToString("N0")đ
                                        </span>
                                    }
                                </td>
                                <td class="text-center small">
                                    <div class="text-dark fw-medium">@item.BatDau.ToString("dd/MM") - @item.KetThuc.ToString("dd/MM/yyyy")</div>
                                    @if (isExpired)
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary px-2 mt-1">Hết hạn</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info-subtle text-info px-2 mt-1">Còn hạn</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="fw-bold">
                                        @item.DaDung <small class="text-muted fw-normal">/ @(item.GioiHanLuotDung?.ToString() ?? "∞")</small>
                                    </div>
                                    <div class="progress mt-1" style="height: 4px; width: 60px; margin: 0 auto;">
                                        @{
                                            // Kiểm tra HasValue trước khi tính toán để tránh lỗi Runtime
                                            var percent = item.GioiHanLuotDung.HasValue && item.GioiHanLuotDung.Value > 0
                                            ? (double)item.DaDung / item.GioiHanLuotDung.Value * 100
                                            : 0;
                                        }
                                        <div class="progress-bar bg-primary" style="width: @percent%"></div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (item.DangHoatDong && !isExpired)
                                    {
                                        <span class="text-success fs-5"><i class="bi bi-check-circle-fill"></i></span>
                                    }
                                    else
                                    {
                                        <span class="text-secondary opacity-50 fs-5"><i class="bi bi-x-circle-fill"></i></span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group btn-group-sm shadow-sm rounded overflow-hidden">
                                        <a asp-action="Details" asp-route-id="@item.MaGiamGiaId" class="btn btn-white border" title="Thống kê">
                                            <i class="bi bi-bar-chart-line text-info"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.MaGiamGiaId" class="btn btn-white border" title="Chỉnh sửa">
                                            <i class="bi bi-pencil-square text-warning"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.MaGiamGiaId" method="post" class="d-inline" onsubmit="return confirm('Xóa mã giảm giá @item.Code?');">
                                            <button type="submit" class="btn btn-white border" title="Xóa">
                                                <i class="bi bi-trash text-danger"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* CSS đồng bộ phong cách Dashboard */
    .bg-primary-subtle {
        background-color: #e7f1ff !important;
        color: #0d6efd !important;
    }

    .bg-danger-subtle {
        background-color: #ffebee !important;
        color: #d32f2f !important;
    }

    .bg-success-subtle {
        background-color: #e8f5e9 !important;
        color: #2e7d32 !important;
    }

    .bg-info-subtle {
        background-color: #e1f5fe !important;
        color: #0288d1 !important;
    }

    .bg-secondary-subtle {
        background-color: #f5f5f5 !important;
        color: #616161 !important;
    }

    .btn-white {
        background-color: #fff;
    }

        .btn-white:hover {
            background-color: #f8f9fa;
        }

    .table thead th {
        font-size: 0.75rem;
        letter-spacing: 0.05rem;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
        font-size: 1.2rem;
        line-height: 1;
        vertical-align: middle;
    }
</style>