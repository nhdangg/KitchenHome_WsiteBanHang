@model KitchenHome_WsiteBanHang.Models.MaGiamGia
@{
    ViewData["Title"] = "Chi tiết mã: " + Model.Code;
    Layout = "~/Areas/Quan_Ly/Views/Shared/_Layout.cshtml";
    // Ensure the type is correct for Core, or just use dynamic if ViewBag is populated correctly
    var lichSu = ViewBag.LichSuDung as List<KitchenHome_WsiteBanHang.Models.SuDungMaGiamGium>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold text-primary mb-0">@Model.Code</h3>
        <small class="text-muted">@Model.TenMa</small>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-secondary me-1"><i class="bi bi-arrow-left"></i> Quay lại</a>
        <a asp-action="Edit" asp-route-id="@Model.MaGiamGiaId" class="btn btn-warning"><i class="bi bi-pencil"></i> Sửa cấu hình</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow border-0 h-100">
            <div class="card-header bg-info text-white fw-bold">Thông số thiết lập</div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Giảm giá:</span>
                        <span class="fw-bold text-danger">
                            @(Model.LoaiGiam == "PHAN_TRAM" ? Model.GiaTriGiam.ToString("N0") + "%" : Model.GiaTriGiam.ToString("N0") + "đ")
                        </span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Đơn tối thiểu:</span>
                        <span class="fw-bold">@Model.DonHangToiThieu.ToString("N0")đ</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Giảm tối đa:</span>
                        <span class="fw-bold">@(Model.GiamToiDa.HasValue? Model.GiamToiDa.Value.ToString("N0") + "đ" : "Không giới hạn")</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Lượt dùng tối đa:</span>
                        <span class="fw-bold">@(Model.GioiHanLuotDung.HasValue? Model.GioiHanLuotDung.ToString() : "∞")</span>
                    </li>
                    <li class="list-group-item">
                        <div class="small text-muted mb-1">Thời gian áp dụng:</div>
                        <div class="fw-bold text-dark d-flex flex-column align-items-center bg-light p-2 rounded">
                            <span>@Model.BatDau.ToString("dd/MM/yyyy HH:mm")</span>
                            <i class="bi bi-arrow-down-short text-muted"></i>
                            <span>@Model.KetThuc.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow border-0 h-100">
            <div class="card-header bg-white fw-bold border-bottom d-flex justify-content-between align-items-center">
                <span><i class="bi bi-clock-history me-2"></i> Lịch sử sử dụng <span class="badge bg-secondary rounded-pill ms-1">@Model.DaDung lượt</span></span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Khách hàng</th>
                                <th>Mã đơn hàng</th>
                                <th class="text-center">Ngày dùng</th>
                                <th class="text-end">Trạng thái đơn</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (lichSu != null && lichSu.Any())
                            {
                                foreach (var item in lichSu)
                                {
                                    <tr>
                                        <td>
                                            @if (item.KhachHang != null)
                                            {
                                                <div class="fw-bold text-dark">@item.KhachHang.HoTen</div>
                                                <div class="small text-muted"><i class="bi bi-telephone me-1"></i>@item.KhachHang.SoDienThoai</div>
                                            }
                                            else
                                            {
                                                <span class="text-muted fst-italic">Khách vãng lai</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.DonHang != null)
                                            {
                                                <a asp-controller="DonHang" asp-action="Details" asp-route-id="@item.DonHangId" class="text-decoration-none fw-bold font-monospace">
                                                    #@item.DonHang.MaDonHang
                                                </a>
                                            }
                                        </td>
                                        <td class="text-center small">@item.NgaySuDung.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="text-end">
                                            @if (item.DonHang != null)
                                            {
                                                if (item.DonHang.TrangThai == "HUY")
                                                {
                                                    <span class="badge bg-danger">Đã hủy</span>
                                                }
                                                else if (item.DonHang.TrangThai == "HOAN_TAT")
                                                {

                                                    <span class="badge bg-success">Hoàn tất</span>
                                                }
                                                else
                                                {

                                                    <span class="badge bg-secondary">@item.DonHang.TrangThai</span>
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-5">
                                        <i class="bi bi-inbox display-4 d-block mb-3 opacity-25"></i>
                                        Chưa có đơn hàng nào sử dụng mã này.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>