@using KitchenHome_WsiteBanHang.Models
@model List<SanPham>

@{
    ViewData["Title"] = "Sản phẩm yêu thích";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container my-5">
    <div class="d-flex align-items-center mb-4">
        <h2 class="fw-bold text-uppercase mb-0">Danh Sách Yêu Thích</h2>
        <span class="badge bg-danger ms-2 rounded-pill">@(Model != null ? Model.Count : 0) sản phẩm</span>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 45%;">Sản phẩm</th>
                                        <th style="width: 20%;">Đơn giá</th>
                                        <th style="width: 20%;">Trạng thái</th>
                                        <th style="width: 15%;" class="text-end">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sp in Model)
                                    {
                                        // --- 1. LOGIC ẢNH THÔNG MINH ---
                                        string imgUrl = sp.AnhDaiDien ?? "";
                                        if (!imgUrl.StartsWith("http") && !imgUrl.StartsWith("/"))
                                        {
                                            imgUrl = Url.Content("~/IMAGE/Img_SanPham/" + imgUrl);
                                        }

                                        // --- 2. LOGIC GIÁ & TỒN KHO ---
                                        // Lấy biến thể đầu tiên (nhờ .ThenInclude ở Controller nên ko bị null nữa)
                                        var variant = sp.BienTheSanPhams?.FirstOrDefault(v => v.DangHoatDong);

                                        decimal giaBan = 0;
                                        bool conHang = false;

                                        if (variant != null)
                                        {
                                            giaBan = (variant.GiaKhuyenMai.HasValue && variant.GiaKhuyenMai > 0)
                                            ? variant.GiaKhuyenMai.Value
                                            : variant.GiaBan;

                                            // Kiểm tra tồn kho (giả sử > 0 là còn hàng)
                                            conHang = variant.SoLuongToiThieu > 0;
                                        }

                                        <tr>
                                            <td data-label="Sản phẩm">
                                                <div class="d-flex align-items-center p-2">
                                                    <a asp-controller="Home" asp-action="ChiTiet" asp-route-id="@sp.SanPhamId">
                                                        <img src="@imgUrl"
                                                             style="width: 80px; height: 80px; object-fit: cover;"
                                                             class="rounded border p-1 me-3 bg-white"
                                                             onerror="this.onerror=null;this.src='/images/no-image.png';" />
                                                    </a>

                                                    <div>
                                                        <h6 class="mb-1">
                                                            <a asp-controller="Home" asp-action="ChiTiet" asp-route-id="@sp.SanPhamId"
                                                               class="text-decoration-none text-dark fw-bold">
                                                                @sp.TenSanPham
                                                            </a>
                                                        </h6>
                                                        <small class="text-muted">Mã SP: @sp.MaSanPham</small>
                                                    </div>
                                                </div>
                                            </td>

                                            <td data-label="Đơn giá">
                                                @if (giaBan > 0)
                                                {
                                                    <span class="fw-bold text-danger fs-5">@giaBan.ToString("N0") đ</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">Liên hệ</span>
                                                }
                                            </td>

                                            <td data-label="Trạng thái">
                                                @if (conHang)
                                                {
                                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">
                                                        <i class="bi bi-check-circle me-1"></i> Còn hàng
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill">
                                                        <i class="bi bi-x-circle me-1"></i> Hết hàng
                                                    </span>
                                                }
                                            </td>

                                            <td class="text-end pe-3" data-label="Hành động">
                                                <div class="d-flex justify-content-end gap-2">
                                                    @if (conHang && variant != null)
                                                    {
                                                        <a asp-controller="GioHang" asp-action="Them" asp-route-variantId="@variant.BienTheId"
                                                           class="btn btn-primary btn-sm rounded-pill px-3"
                                                           title="Thêm vào giỏ hàng">
                                                            <i class="bi bi-cart-plus me-1"></i> Mua ngay
                                                        </a>
                                                    }

                                                    <a asp-controller="YeuThich" asp-action="XoaYeuThich" asp-route-id="@sp.SanPhamId"
                                                       class="btn btn-outline-danger btn-sm rounded-circle"
                                                       onclick="return confirm('Bỏ sản phẩm này khỏi danh sách yêu thích?');"
                                                       title="Xóa khỏi danh sách">
                                                        <i class="bi bi-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="card-footer bg-white py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill">
                                <i class="bi bi-arrow-left me-1"></i> Tiếp tục xem sản phẩm
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-light rounded-3">
            <div class="mb-4">
                <span class="d-inline-block p-4 bg-white rounded-circle shadow-sm">
                    <i class="bi bi-heart text-danger display-4 opacity-50"></i>
                </span>
            </div>
            <h3 class="fw-bold text-dark">Danh sách yêu thích trống</h3>
            <p class="text-muted mb-4">Bạn chưa lưu sản phẩm nào. Hãy tìm kiếm sản phẩm ưng ý và thả tim nhé!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm">
                Khám phá ngay
            </a>
        </div>
    }
</div>

<style>
    /* CSS để làm đẹp bảng và responsive */
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: background-color 0.2s ease-in-out;
    }

    /* Mobile Responsive */
    @@media (max-width: 768px) {
        .table thead {
            display: none;
        }

        .table tr {
            display: block;
            margin-bottom: 1rem;
            border: 1px solid #dee2e6;
            border-radius: 0.5rem;
            background: #fff;
        }

        .table td {
            display: block;
            text-align: right;
            border: none;
            padding: 0.5rem 1rem;
            border-bottom: 1px solid #f0f0f0;
        }

            .table td:last-child {
                border-bottom: none;
            }

            .table td::before {
                content: attr(data-label);
                float: left;
                font-weight: bold;
                text-transform: uppercase;
                font-size: 0.85rem;
                color: #6c757d;
                margin-top: 5px;
            }

        .d-flex.align-items-center {
            flex-direction: row;
            text-align: left;
        }
    }
</style>