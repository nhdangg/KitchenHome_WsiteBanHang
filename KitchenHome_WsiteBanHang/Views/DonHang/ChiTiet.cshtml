@model KitchenHome_WsiteBanHang.Models.DonHang

@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.MaDonHang;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var diaChi = Model.DonHangDiaChiGiao;
}

<div class="container py-5 bg-light-subtle">
    @* --- HEADER & BREADCRUMB --- *@
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                Đơn hàng <span class="text-primary">#@Model.MaDonHang</span>
            </h2>
            <div class="text-muted small">
                <i class="bi bi-calendar-event me-1"></i> Ngày đặt: @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")
                <span class="mx-2">|</span>
                <span class="badge @(Model.TrangThai == "HUY" ? "bg-danger" : (Model.TrangThai == "HOAN_TAT" ? "bg-success" : "bg-warning text-dark")) rounded-pill px-3">
                    @Model.TrangThai
                </span>
            </div>
        </div>
        <div class="mt-3 mt-md-0">
            <a asp-action="Index" class="btn btn-white border shadow-sm rounded-pill px-4 fw-bold text-secondary hover-primary">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row g-4">
        @* --- CỘT TRÁI: THÔNG TIN (Sticky trên màn hình lớn) --- *@
        <div class="col-lg-4">
            <div class="vstack gap-4">

                @* 1. THÔNG TIN NHẬN HÀNG *@
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-header bg-primary bg-opacity-10 py-3 border-0">
                        <h6 class="fw-bold text-primary mb-0 d-flex align-items-center">
                            <i class="bi bi-geo-alt-fill me-2 fs-5"></i> Thông tin nhận hàng
                        </h6>
                    </div>
                    <div class="card-body p-4">
                        @if (diaChi != null)
                        {
                            <div class="mb-3">
                                <small class="text-uppercase text-muted fw-bold" style="font-size: 0.75rem;">Người nhận</small>
                                <div class="d-flex align-items-center mt-1">
                                    <div class="avatar-circle bg-light text-primary fw-bold me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        @diaChi.TenNguoiNhan.Substring(0, 1)
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@diaChi.TenNguoiNhan</div>
                                        <div class="text-muted small">@diaChi.SdtnguoiNhan</div>
                                    </div>
                                </div>
                            </div>

                            <hr class="border-light my-3">

                            <div class="mb-0">
                                <small class="text-uppercase text-muted fw-bold" style="font-size: 0.75rem;">Địa chỉ giao hàng</small>
                                <p class="mt-1 mb-0 text-dark">
                                    @diaChi.DiaChiCuThe <br>
                                    <span class="text-muted small">@diaChi.PhuongXa, @diaChi.QuanHuyen, @diaChi.TinhThanh</span>
                                </p>
                            </div>
                        }
                    </div>
                </div>

                @* 2. THÔNG TIN THANH TOÁN & GHI CHÚ *@
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <div class="mb-4">
                            <h6 class="fw-bold text-dark mb-3"><i class="bi bi-credit-card-2-front me-2 text-warning"></i>Thanh toán</h6>
                            @foreach (var tt in Model.ThanhToans)
                            {
                                <div class="d-flex align-items-center p-2 border rounded-3 bg-light mb-2">
                                    <i class="bi bi-check-circle-fill text-success me-2"></i>
                                    <span class="fw-semibold text-dark small">
                                        @(tt.PhuongThuc?.TenPhuongThuc ?? "Thanh toán khi nhận hàng")
                                    </span>
                                </div>
                            }
                        </div>

                        <div class="mb-0">
                            <h6 class="fw-bold text-dark mb-2"><i class="bi bi-pencil-square me-2 text-info"></i>Ghi chú</h6>
                            <div class="p-3 bg-light rounded-3 text-muted small fst-italic border border-light">
                                @(string.IsNullOrEmpty(Model.GhiChu) ? "Không có ghi chú cho đơn hàng này." : Model.GhiChu)
                            </div>
                        </div>
                    </div>
                </div>

                @* 3. MÃ GIẢM GIÁ (Nếu có) *@
                @if (Model.SuDungMaGiamGium != null && Model.GiamGia > 0)
                {
                    <div class="card border-0 shadow-sm rounded-4 bg-success bg-opacity-10 border-success border-opacity-25">
                        <div class="card-body p-3 d-flex justify-content-between align-items-center">
                            <div>
                                <small class="text-success fw-bold d-block text-uppercase">Mã giảm giá</small>
                                <span class="fw-bold text-dark">@Model.SuDungMaGiamGium.MaGiamGia.Code</span>
                            </div>
                            <div class="text-end">
                                <small class="text-success fw-bold d-block text-uppercase">Tiết kiệm</small>
                                <span class="fw-bold text-danger fs-5">-@Model.GiamGia.ToString("N0")đ</span>
                            </div>
                        </div>
                    </div>
                }

                @* 4. NÚT HỦY ĐƠN *@
                @if (Model.TrangThai == "CHO_XAC_NHAN")
                {
                    <div class="d-grid">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-outline-danger btn-lg rounded-pill fw-bold py-3 shadow-sm hover-danger-fill" onclick="huyDonHang(@Model.DonHangId)">
                            <i class="bi bi-x-circle me-2"></i> Hủy Đơn Hàng
                        </button>
                        <small class="text-muted text-center mt-2">* Chỉ hủy được khi chưa xác nhận.</small>
                    </div>
                }
            </div>
        </div>

        @* --- CỘT PHẢI: SẢN PHẨM & LỊCH SỬ --- *@
        <div class="col-lg-8">
            <div class="vstack gap-4">

                @* 1. DANH SÁCH SẢN PHẨM *@
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-header bg-white py-3 border-bottom">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="fw-bold mb-0 d-flex align-items-center">
                                <i class="bi bi-bag-check-fill text-success me-2 fs-5"></i> Sản phẩm đã đặt
                            </h6>
                            <span class="badge bg-light text-dark border rounded-pill">@Model.ChiTietDonHangs.Count món</span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr class="text-muted small text-uppercase">
                                        <th class="ps-4 py-3 border-0">Sản phẩm</th>
                                        <th class="text-center py-3 border-0">Giá</th>
                                        <th class="text-center py-3 border-0">SL</th>
                                        <th class="text-end pe-4 py-3 border-0">Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.ChiTietDonHangs)
                                    {
                                        // ========================================================
                                        // [UPDATED] LOGIC ẢNH THÔNG MINH
                                        // ========================================================
                                        string imgUrl = item.BienThe?.SanPham?.AnhDaiDien ?? "";

                                        // Nếu không phải http (ảnh mạng) và không bắt đầu bằng / (ảnh local gốc)
                                        // thì nối thêm đường dẫn thư mục ảnh
                                        if (!string.IsNullOrEmpty(imgUrl) && !imgUrl.StartsWith("http") && !imgUrl.StartsWith("/"))
                                        {
                                            imgUrl = Url.Content("~/IMAGE/Img_SanPham/" + imgUrl);
                                        }

                                        // Nếu rỗng thì dùng ảnh mặc định
                                        if (string.IsNullOrEmpty(imgUrl))
                                        {
                                            imgUrl = "/images/no-image.png";
                                        }
                                        // ========================================================

                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <div class="position-relative me-3">
                                                        <img src="@imgUrl" class="rounded-3 border bg-white" style="width: 64px; height: 64px; object-fit: cover;">
                                                    </div>
                                                    <div>
                                                        <h6 class="mb-1 fw-bold text-dark text-truncate" style="max-width: 280px;" title="@item.TenSanPhamLuu">
                                                            @item.TenSanPhamLuu
                                                        </h6>
                                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-10 rounded-pill fw-normal px-2 py-1" style="font-size: 0.75rem;">
                                                            @(item.BienThe?.TenBienThe ?? item.Sku)
                                                        </span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center text-muted fw-semibold">@item.DonGia.ToString("N0")đ</td>
                                            <td class="text-center fw-bold">x @item.SoLuong</td>
                                            <td class="text-end pe-4 fw-bold text-primary">@((item.SoLuong * item.DonGia).ToString("N0"))đ</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="bg-light bg-opacity-50">
                                    <tr>
                                        <td colspan="3" class="text-end text-muted pt-4 border-0">Tạm tính:</td>
                                        <td class="text-end pe-4 pt-4 fw-bold border-0">@Model.TamTinh.ToString("N0")đ</td>
                                    </tr>
                                    <tr>
                                        <td colspan="3" class="text-end text-muted border-0">Phí vận chuyển:</td>
                                        <td class="text-end pe-4 border-0 fw-bold">@Model.PhiVanChuyen.ToString("N0")đ</td>
                                    </tr>
                                    <tr>
                                        <td colspan="3" class="text-end pb-4 border-0"><span class="fw-bold text-dark fs-5">Tổng thanh toán:</span></td>
                                        <td class="text-end pe-4 pb-4 border-0">
                                            <span class="fs-4 fw-bolder text-danger">@Model.TongTien.ToString("N0")đ</span>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>

                @* 2. LỊCH SỬ ĐƠN HÀNG (TIMELINE) *@
                @if (Model.LichSuTrangThaiDonHangs != null && Model.LichSuTrangThaiDonHangs.Any())
                {
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-header bg-white py-3 border-bottom">
                            <h6 class="fw-bold mb-0 text-dark"><i class="bi bi-clock-history text-info me-2 fs-5"></i> Hành trình đơn hàng</h6>
                        </div>
                        <div class="card-body p-4">
                            <div class="timeline">
                                @foreach (var ls in Model.LichSuTrangThaiDonHangs.OrderByDescending(x => x.NgayTao))
                                {
                                    <div class="timeline-item d-flex pb-4 position-relative">
                                        @* Dot & Line *@
                                        <div class="timeline-marker me-3 d-flex flex-column align-items-center" style="width: 24px;">
                                            <div class="timeline-dot bg-primary rounded-circle border border-3 border-white shadow-sm" style="width: 14px; height: 14px; z-index: 2;"></div>
                                            <div class="timeline-line bg-light h-100 position-absolute" style="width: 2px; top: 14px; bottom: 0; left: 11px; z-index: 1;"></div>
                                        </div>

                                        @* Content *@
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between align-items-start mb-1">
                                                <h6 class="fw-bold text-dark mb-0">@ls.TrangThaiMoi</h6>
                                                <small class="text-muted fw-semibold">@ls.NgayTao.ToString("HH:mm dd/MM/yyyy")</small>
                                            </div>

                                            @if (!string.IsNullOrEmpty(ls.TrangThaiCu))
                                            {
                                                <div class="text-muted small mb-1">
                                                    Chuyển từ <span class="fw-semibold">@ls.TrangThaiCu</span>
                                                </div>
                                            }

                                            @if (!string.IsNullOrEmpty(ls.GhiChu))
                                            {
                                                <div class="p-2 bg-light rounded-2 mt-2 border border-light text-muted small fst-italic">
                                                    <i class="bi bi-info-circle me-1"></i> @ls.GhiChu
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* CSS BỔ SUNG *@
<style>
    /* Ẩn đường line ở item cuối cùng của timeline */
    .timeline-item:last-child .timeline-line {
        display: none;
    }

    /* Hiệu ứng hover cho nút Quay lại */
    .hover-primary:hover {
        background-color: #0d6efd;
        color: #fff !important;
        border-color: #0d6efd !important;
    }

    /* Hiệu ứng hover cho nút Hủy */
    .hover-danger-fill:hover {
        background-color: #dc3545;
        color: #fff;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Giữ nguyên script cũ của bạn
        function huyDonHang(id) {
            Swal.fire({
                title: 'Hủy đơn hàng?',
                text: "Bạn có chắc chắn muốn hủy đơn hàng này không?",
                icon: 'warning',
                input: 'text',
                inputPlaceholder: 'Nhập lý do hủy (không bắt buộc)...',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Đồng ý hủy',
                cancelButtonText: 'Không, giữ lại',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.showLoading();
                    $.ajax({
                        url: '@Url.Action("HuyDon", "DonHang")',
                        type: 'POST',
                        data: {
                            id: id,
                            lyDoHuy: result.value,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Thành công!',
                                    text: res.msg,
                                    timer: 2000,
                                    showConfirmButton: false
                                }).then(() => location.reload());
                            } else {
                                Swal.fire('Lỗi!', res.msg, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('Lỗi!', 'Không thể kết nối đến máy chủ.', 'error');
                        }
                    });
                }
            })
        }
    </script>
}