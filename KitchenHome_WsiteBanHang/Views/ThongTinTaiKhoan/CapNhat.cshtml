@model KitchenHome_WsiteBanHang.Models.KhachHang

@{
    ViewBag.Title = "Cập nhật hồ sơ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-person-gear me-2"></i>Cập nhật thông tin cá nhân</h5>
                </div>
                <div class="card-body p-4">
                    @using (Html.BeginForm("CapNhat", "ThongTinTaiKhoan", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        @Html.HiddenFor(m => m.KhachHangId)
                        @Html.HiddenFor(m => m.TaiKhoanId)
                        @Html.HiddenFor(m => m.MaKhachHang)

                        <div class="mb-3">
                            <label class="form-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                            @Html.TextBoxFor(m => m.HoTen, new { @class = "form-control", @placeholder = "Nhập họ tên của bạn", required = "required" })
                            @Html.ValidationMessageFor(m => m.HoTen, "", new { @class = "text-danger small" })
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Số điện thoại</label>
                                @Html.TextBoxFor(m => m.SoDienThoai, new { @class = "form-control", type = "tel" })
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Giới tính</label>
                                @Html.DropDownListFor(m => m.GioiTinh, new List<SelectListItem> {
                                new SelectListItem { Text = "Nam", Value = "Nam" },
                                                        new SelectListItem { Text = "Nữ", Value = "Nữ" },
                                                        new SelectListItem { Text = "Khác", Value = "Khác" }
                                                        }, "Chọn giới tính", new { @class = "form-select" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Email</label>
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email" })
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Ngày sinh</label>
                            <input type="date" name="NgaySinh" class="form-control"
                                   value="@(Model.NgaySinh.HasValue? Model.NgaySinh.Value.ToString("yyyy-MM-dd") : "")" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Ghi chú / Địa chỉ</label>
                        @Html.TextAreaFor(m => m.GhiChu, new { @class = "form-control", rows = "3" })
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="@Url.Action("Index")" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save me-1"></i> Lưu thay đổi
                        </button>
                    </div>
                                        }
                </div>
            </div>
        </div>
    </div>
</div>