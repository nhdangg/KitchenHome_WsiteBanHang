@model KitchenHome_WsiteBanHang.Models.Class_phu.CheckoutViewModel

@{
    ViewData["Title"] = "Thanh toán";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <h2 class="text-uppercase fw-bold mb-4">Thanh toán đơn hàng</h2>

    <form asp-action="DatHang" method="post">
        @Html.AntiForgeryToken()

        @* ===== HIỂN THỊ LỖI ===== *@
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mb-4">
                <strong>Vui lòng kiểm tra lại:</strong>
                <div asp-validation-summary="All"></div>
            </div>
        }

        <div class="row">
            @* ================= CỘT TRÁI ================= *@
            <div class="col-lg-7">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold">
                            <i class="bi bi-person-lines-fill text-danger me-2"></i>
                            Thông tin giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Họ và tên *</label>
                                <input asp-for="HoTen" class="form-control" />
                                <span asp-validation-for="HoTen" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Số điện thoại *</label>
                                <input asp-for="SoDienThoai" class="form-control" />
                                <span asp-validation-for="SoDienThoai" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Email *</label>
                                <input asp-for="Email" class="form-control" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Địa chỉ nhận hàng *</label>
                                <input asp-for="DiaChiCuThe" class="form-control" />
                                <span asp-validation-for="DiaChiCuThe" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <input asp-for="TinhThanh" class="form-control" placeholder="Tỉnh/Thành" />
                            </div>
                            <div class="col-md-4">
                                <input asp-for="QuanHuyen" class="form-control" placeholder="Quận/Huyện" />
                            </div>
                            <div class="col-md-4">
                                <input asp-for="PhuongXa" class="form-control" placeholder="Phường/Xã" />
                            </div>

                            <div class="col-12">
                                <label class="form-label">Ghi chú</label>
                                <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                @* ===== THANH TOÁN ===== *@
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold">
                            <i class="bi bi-credit-card-2-front-fill text-primary me-2"></i>
                            Thanh toán
                        </h5>
                    </div>

                    <div class="card-body">
                        @foreach (var pt in Model.DanhSachPhuongThuc)
                        {
                            <div class="form-check mb-3 border rounded p-3">
                                <input type="radio"
                                       asp-for="PhuongThucThanhToanId"
                                       value="@pt.PhuongThucId"
                                       class="form-check-input mt-1" />


                                <label class="form-check-label fw-bold w-100">
                                    @pt.TenPhuongThuc
                                    <div class="text-muted small mt-1">
                                        @(pt.MaPhuongThuc == "COD"
                                            ? "Thanh toán khi nhận hàng"
                                            : "Thanh toán qua cổng điện tử")
                                    </div>
                                </label>
                            </div>
                        }

                        <span asp-validation-for="PhuongThucThanhToanId" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            @* ================= CỘT PHẢI ================= *@
            <div class="col-lg-5">
                <div class="card shadow-sm border-0 sticky-top" style="top:20px">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold">
                            Đơn hàng (@Model.CartItems.Count sản phẩm)
                        </h5>
                    </div>

                    <div class="card-body">
                        <ul class="list-group list-group-flush mb-3">
                            @foreach (var item in Model.CartItems)
                            {
                                <li class="list-group-item px-0 d-flex justify-content-between">
                                    <div class="d-flex">
                                        <img src="@(string.IsNullOrEmpty(item.AnhDaiDien)
                                            ? "/images/no-image.png"
                                            : item.AnhDaiDien)"
                                             style="width:50px;height:50px;object-fit:cover"
                                             class="rounded border me-2" />

                                        <div>
                                            <h6 class="mb-0">@item.TenSanPham</h6>
                                            <small class="text-muted">@item.TenBienThe</small>
                                        </div>
                                    </div>
                                    <span>@item.ThanhTien.ToString("N0") đ</span>
                                </li>
                            }
                        </ul>

                        <div class="d-flex justify-content-between">
                            <span>Tạm tính</span>
                            <span class="fw-bold">@Model.TongTienHang.ToString("N0") đ</span>
                        </div>

                        <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                            <span>Phí vận chuyển</span>
                            <span class="fw-bold">@Model.PhiVanChuyen.ToString("N0") đ</span>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold">Mã giảm giá</label>
                            <input asp-for="MaGiamGia" class="form-control" />
                            <span asp-validation-for="MaGiamGia" class="text-danger small"></span>
                        </div>

                        @if (Model.TienGiam > 0)
                        {
                            <div class="d-flex justify-content-between text-success">
                                <span>Giảm giá</span>
                                <span>-@Model.TienGiam.ToString("N0") đ</span>
                            </div>
                        }

                        <div class="d-flex justify-content-between mt-3">
                            <span class="h5">Tổng cộng</span>
                            <span class="h4 text-danger fw-bold">
                                @Model.TongThanhToan.ToString("N0") đ
                            </span>
                        </div>

                        @* ===== HIDDEN – BẮT BUỘC ===== *@
                        <input type="hidden" asp-for="PhiVanChuyen" />
                        <input type="hidden" asp-for="TienGiam" />
                        <input type="hidden" asp-for="TongThanhToan" />

                        <button type="submit"
                                class="btn btn-primary w-100 py-3 fw-bold text-uppercase mt-3">
                            Đặt hàng ngay
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
