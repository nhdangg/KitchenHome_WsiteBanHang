@model IEnumerable<NhatKyCongThanhToan>

<style>
    /* CSS tùy chỉnh nhỏ để bảng đẹp hơn */
    .table-custom thead th {
        background-color: #f8f9fa;
        color: #6c757d;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 2px solid #e9ecef;
    }

    .table-custom tbody td {
        vertical-align: middle;
        padding: 1rem 0.75rem;
        color: #212529;
    }

    .empty-state-icon {
        font-size: 3rem;
        color: #dee2e6;
    }
</style>

<div class="card border-0 shadow-sm rounded-3 overflow-hidden">
    @if (!Model.Any())
    {
        <div class="card-body text-center py-5">
            <div class="empty-state-icon mb-3">
                <i class="bi bi-receipt-cutoff"></i>
            </div>
            <h6 class="text-muted fw-normal">Đơn hàng chưa có lịch sử thanh toán</h6>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-custom table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">Thời gian</th>
                        <th>Cổng TT</th>
                        <th>Mã kết quả</th>
                        <th>Phương thức</th>
                        <th class="text-end pe-4">Số tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex flex-column">
                                    <span class="fw-bold text-dark">@log.NgayTao.ToString("HH:mm")</span>
                                    <small class="text-muted">@log.NgayTao.ToString("dd/MM/yyyy")</small>
                                </div>
                            </td>
                            <td>
                                <span class="d-inline-block text-truncate" style="max-width: 150px;">
                                    @log.CongThanhToan
                                </span>
                            </td>
                            <td>
                                <code class="text-primary bg-light px-2 py-1 rounded">@log.MaKetQua</code>
                            </td>
                            <td>
                                @if (log.ThanhToan?.PhuongThuc != null)
                                {
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 rounded-pill px-3 py-2">
                                        @log.ThanhToan.PhuongThuc.TenPhuongThuc
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <span class="text-danger fw-bold fs-6">
                                    @log.ThanhToan?.SoTien.ToString("N0") <small>đ</small>
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>